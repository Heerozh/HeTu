#: hetu/manager.py:56
#, python-brace-format
msgid "Backend {backend}未找到"
msgstr "Backend {backend} nicht gefunden"

#: hetu/manager.py:100
#, python-brace-format
msgid "⚠️  组件 {comp_name} 的表结构需要迁移Schema。"
msgstr ""
"⚠️  Die Tabellenstruktur der Komponente {comp_name} benötigt eine Schema-"
"Migration."

#: hetu/manager.py:107
#, python-brace-format
msgid "⚠️  组件 {comp_name} 的表需要迁移到新集群。"
msgstr ""
"⚠️  Die Tabelle der Komponente {comp_name} muss zum neuen Cluster "
"migriert werden."

#: hetu/cli/__init__.py:25
msgid "河图数据库"
msgstr "Hetu-Datenbank"

#: hetu/cli/__init__.py:29
msgid "执行操作"
msgstr "Aktion ausführen"

#: hetu/cli/base.py:21
msgid "Boolean value expected."
msgstr "Boolescher Wert erwartet."

#: hetu/cli/build.py:22
msgid "生成客户端SDK C# 类型代码"
msgstr "C#-Typencode für Client-SDK generieren"

#: hetu/cli/build.py:26 hetu/cli/migrate.py:46 hetu/cli/start.py:82
msgid "河图app的py文件"
msgstr "Py-Datei der Hetu-App"

#: hetu/cli/build.py:33
msgid "编译app.py中哪个namespace下的数据类型"
msgstr "Unter welchem Namespace in app.py Datentypen kompilieren"

#: hetu/cli/build.py:37
msgid "输出文件路径"
msgstr "Ausgabedateipfad"

#: hetu/cli/build.py:46 hetu/cli/migrate.py:92
#, python-brace-format
msgid "无法加载app文件 {app_file}"
msgstr "App-Datei {app_file} kann nicht geladen werden"

#: hetu/cli/build.py:59
#, python-brace-format
msgid "✅ 已生成C#代码到 {output}"
msgstr "✅ C#-Code wurde nach {output} generiert"

#: hetu/cli/migrate.py:34
msgid "在数据库执行Schema升级脚本,如果没有则创建，如果无变更则跳过。同时还会进行临时表的清空。应该在CI/CD流程中，每次启动服务器前执行一次。"
msgstr ""
"Führt Schema-Upgrade-Skripte in der Datenbank aus, erstellt sie falls "
"nicht vorhanden und überspringt sie bei keiner Änderung. Zudem werden "
"temporäre Tabellen geleert. Sollte im CI/CD-Prozess einmal vor jedem "
"Serverstart ausgeführt werden."

#: hetu/cli/migrate.py:41 hetu/cli/start.py:100
msgid "后端数据库地址"
msgstr "Adresse der Backend-Datenbank"

#: hetu/cli/migrate.py:51 hetu/cli/start.py:89
msgid "启动app.py中哪个namespace下的System"
msgstr "Welches System unter welchem Namespace in app.py gestartet werden soll"

#: hetu/cli/migrate.py:54 hetu/cli/start.py:92
msgid "实例名称，每个实例是一个副本"
msgstr "Instanzname, jede Instanz ist eine Replik"

#: hetu/cli/migrate.py:58
msgid "通过yml配置文件读取后端数据库地址"
msgstr ""
"Liest die Adresse der Backend-Datenbank aus einer YAML-"
"Konfigurationsdatei."

#: hetu/cli/migrate.py:64
msgid "自动确认数据备份提示"
msgstr "Bestätigt automatisch die Datenbank-Backup-Aufforderung."

#: hetu/cli/migrate.py:70
msgid "强制执行升级迁移，丢弃无法迁移的数据。请勿在生产环境使用此选项！"
msgstr ""
"Erzwingt das Upgrade-Migration und verwirft nicht migrierbare Daten. "
"Diese Option nicht in der Produktionsumgebung verwenden!"

#: hetu/cli/migrate.py:104
msgid "⚠️  升级数据库表结构可能会导致数据丢失，请确保已备份数据。确认继续请输 y ，取消请输其他键然后回车："
msgstr ""
"⚠️  Das Upgrade der Datenbanktabellenstruktur kann zu Datenverlust "
"führen. Stellen Sie sicher, dass Sie Ihre Daten gesichert haben. Geben "
"Sie y ein, um fortzufahren, oder eine andere Taste gefolgt von Enter, um "
"abzubrechen:"

#: hetu/cli/migrate.py:109 hetu/cli/migrate.py:136
msgid "❌  升级迁移已取消。"
msgstr "❌  Upgrade-Migration wurde abgebrochen."

#: hetu/cli/migrate.py:126
msgid "❗ Component有数据删除或类型变更，请修改自动生成的迁移脚本，手动处理这些属性。或使用--drop-data参数直接丢弃这些属性。"
msgstr ""
"❗ Bei der Component gibt es Datenlöschungen oder Typänderungen. Bitte "
"ändern Sie das automatisch generierte Migrationsskript, um diese "
"Attribute manuell zu behandeln. Oder verwenden Sie den Parameter --drop-"
"data, um diese Attribute direkt zu verwerfen."

#: hetu/cli/migrate.py:133
msgid "⚠️  确认强制迁移请输 y ，取消请输其他键然后回车："
msgstr ""
"⚠️  Geben Sie y ein, um die erzwungene Migration zu bestätigen, oder eine"
" andere Taste gefolgt von Enter, um abzubrechen:"

#: hetu/cli/migrate.py:139
#, python-brace-format
msgid "⚠️  正在强制迁移 {instance_name} 服所有表结构，可能会丢失数据..."
msgstr ""
"⚠️  Erzwinge Migration der Tabellenstruktur für alle Server von "
"{instance_name}. Datenverlust ist möglich..."

#: hetu/cli/migrate.py:147
#, python-brace-format
msgid "🧹 正在清除 {instance_name} 服易失数据..."
msgstr "🧹 Räume flüchtige Daten für den Server {instance_name} auf..."

#: hetu/cli/migrate.py:150
#, python-brace-format
msgid "✅  {instance_name} 服升级迁移完成！"
msgstr "✅  Upgrade-Migration für den Server {instance_name} abgeschlossen!"

#: hetu/cli/migrate.py:151
msgid "🎉  恭喜！所有数据库表结构均已升级完成！"
msgstr ""
"🎉  Glückwunsch! Alle Datenbanktabellenstrukturen wurden erfolgreich "
"aktualisiert!"

#: hetu/cli/migrate.py:173
msgid "namespace参数不能为空，建议用--config参数"
msgstr ""
"Der Namespace-Parameter darf nicht leer sein. Es wird empfohlen, den "
"Parameter --config zu verwenden."

#: hetu/cli/migrate.py:174
msgid "instance参数不能为空，建议用--config参数"
msgstr ""
"Der Instance-Parameter darf nicht leer sein. Es wird empfohlen, den "
"Parameter --config zu verwenden."

#: hetu/cli/migrate.py:175
msgid "app_file参数不能为空，建议用--config参数"
msgstr ""
"Der app_file-Parameter darf nicht leer sein. Es wird empfohlen, den "
"Parameter --config zu verwenden."

#: hetu/cli/start.py:52
#, python-brace-format
msgid ""
"不支持的数据库URL scheme: '{scheme}'。目前支持 "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"
msgstr ""
"Nicht unterstütztes Datenbank-URL-Schema: '{scheme}'. Derzeit werden "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb "
"unterstützt."

#: hetu/cli/start.py:77
msgid "启动河图服务"
msgstr "Hetu-Dienst starten"

#: hetu/cli/start.py:79
msgid "通过命令行启动参数"
msgstr "Über Befehlszeilen-Startparameter"

#: hetu/cli/start.py:95
msgid "监听的Websocket端口"
msgstr "Websocket-Port, auf dem gelauscht wird"

#: hetu/cli/start.py:104
msgid "工作进程数，可设为 CPU * 1.2"
msgstr "Anzahl der Worker-Prozesse, kann auf CPU * 1.2 gesetzt werden"

#: hetu/cli/start.py:112
msgid "开启debug模式，这会启动代码热更新，并显示更多的log信息。如果设置为2，则对框架内核也启用debug模式，会开启Python协程的Debug模式，速度慢90％。"
msgstr ""
"Debug-Modus aktivieren. Dies startet Hot-Reloading von Code und zeigt "
"mehr Log-Informationen an. Wenn auf 2 gesetzt, wird der Debug-Modus auch "
"für das Framework-Kernel aktiviert, was den Python-Coroutine-Debug-Modus "
"einschaltet und die Geschwindigkeit um 90% verringert."

#: hetu/cli/start.py:122
msgid "证书目录，如果不设置则使用不安全的连接。不建议这里设置，请外加一层反向https代理。填入auto会生成自签https证书。"
msgstr ""
"Zertifikatsverzeichnis. Wenn nicht gesetzt, wird eine unsichere "
"Verbindung verwendet. Es wird nicht empfohlen, dies hier zu setzen; bitte"
" verwenden Sie einen zusätzlichen Reverse-HTTPS-Proxy. 'auto' eingeben, "
"um ein selbstsigniertes HTTPS-Zertifikat zu generieren."

#: hetu/cli/start.py:130
msgid "默认crypto层的auth_key，用于握手签名校验。留空则不启用。"
msgstr ""
"Standard-Auth-Key für die Crypto-Schicht, verwendet für Handshake-"
"Signaturprüfung. Leer lassen, um nicht zu aktivieren."

#: hetu/cli/start.py:137
msgid "配置文件模板见CONFIG_TEMPLATE.yml"
msgstr "Konfigurationsvorlage siehe CONFIG_TEMPLATE.yml"

#: hetu/cli/start.py:155
msgid "--app_file是必须参数，或者用--config"
msgstr "--app_file ist ein erforderlicher Parameter, oder verwenden Sie --config"

#: hetu/cli/start.py:158
msgid "--namespace是必须参数，或者用--config"
msgstr "--namespace ist ein erforderlicher Parameter, oder verwenden Sie --config"

#: hetu/cli/start.py:161
msgid "--instance是必须参数，或者用--config"
msgstr "--instance ist ein erforderlicher Parameter, oder verwenden Sie --config"

#: hetu/cli/start.py:218
#, python-brace-format
msgid "ℹ️ {name}, {mode}, {workers} 个工作进程, 管理进程 pid: {pid}"
msgstr "ℹ️ {name}, {mode}, {workers} Worker-Prozesse, Manager-Prozess-PID: {pid}"

#: hetu/cli/start.py:226
#, python-brace-format
msgid "ℹ️ Python {version} 平台 {platform}"
msgstr "ℹ️ Python {version} Plattform {platform}"

#: hetu/cli/start.py:231
#, python-brace-format
msgid "📡 监听地址： http{s}://{host}:{port}"
msgstr "📡 Lauscht auf Adresse: http{s}://{host}:{port}"

#: hetu/cli/start.py:237
#, python-brace-format
msgid "ℹ️ 消息流协议：json -> {layers} -> Network"
msgstr "ℹ️ Nachrichtenstromprotokoll: json -> {layers} -> Netzwerk"

#: hetu/cli/start.py:244
msgid "⚠️⚠️⚠️ 深度Debug模式开启  ⚠️⚠️⚠️   此模式下Python协程慢90%"
msgstr ""
"⚠️⚠️⚠️ Tiefen-Debug-Modus aktiviert  ⚠️⚠️⚠️   In diesem Modus sind "
"Python-Coroutines 90% langsamer"

#: hetu/common/slowlog.py:72
#, python-brace-format
msgid ""
"⚠️ [📞慢日志] 系统 {name} 执行时间 {elapsed}秒，事务冲突次数 {retry}，平均时间 {avg_time}秒\n"
"{table}"
msgstr ""
"⚠️ [📞 Langsame Abfrage] System {name} Ausführungszeit {elapsed} Sekunden,"
" Transaktionskonflikte {retry}, Durchschnittszeit {avg_time} Sekunden\n"
"{table}"

#: hetu/common/slowlog.py:99
msgid "系统"
msgstr "System"

#: hetu/common/slowlog.py:99
msgid "平均时间"
msgstr "Durchschnittszeit"

#: hetu/common/slowlog.py:99
msgid "平均冲突次数"
msgstr "Durchschnittliche Konflikte"

#: hetu/common/snowflake_id.py:84
#, python-brace-format
msgid "Worker ID不能大于{max}或小于0"
msgstr "Worker ID darf nicht größer als {max} oder kleiner als 0 sein"

#: hetu/common/snowflake_id.py:98
#, python-brace-format
msgid "[❄️ID] 雪花ID生成器初始化完成，Worker ID: {worker_id}, last_timestamp: {ts}"
msgstr ""
"[❄️ID] Snowflake-ID-Generator initialisiert, Worker ID: {worker_id}, "
"last_timestamp: {ts}"

#: hetu/common/snowflake_id.py:110
msgid "SnowflakeID 未初始化，请先调用 init() 方法。"
msgstr "SnowflakeID nicht initialisiert, bitte zuerst die init()-Methode aufrufen."

#: hetu/common/snowflake_id.py:119
#, python-brace-format
msgid "[❄️ID] 时钟回拨了 {ms} 毫秒。"
msgstr "[❄️ID] Uhr wurde um {ms} Millisekunden zurückgestellt."

#: hetu/common/snowflake_id.py:154 hetu/common/snowflake_id.py:170
msgid "[❄️ID] 每毫秒只能生成有限的ID，需要休眠 1 ms"
msgstr ""
"[❄️ID] Pro Millisekunde können nur begrenzte IDs generiert werden, muss 1"
" ms warten"

#: hetu/data/component.py:253
msgid "Component重复定义"
msgstr "Doppelte Definition der Komponente"

#: hetu/data/component.py:369
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是Python关键字。"
msgstr ""
"{cname}.{fname}-Eigenschaftsdefinition fehlerhaft, Eigenschaftsname darf "
"kein Python-Schlüsselwort sein."

#: hetu/data/component.py:375
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是C#关键字。"
msgstr ""
"{cname}.{fname}-Eigenschaftsdefinition fehlerhaft, Eigenschaftsname darf "
"kein C#-Schlüsselwort sein."

#: hetu/data/component.py:381
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不能为0长度。str类型请用'<U8'方式定义"
msgstr ""
"Der dtype der Eigenschaft {cname}.{fname} darf nicht die Länge 0 haben. "
"Für str-Typ bitte mit '<U8' definieren."

#: hetu/data/component.py:384
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不支持void类型"
msgstr "Der dtype der Eigenschaft {cname}.{fname} unterstützt den void-Typ nicht."

#: hetu/data/component.py:394
#, python-brace-format
msgid "⚠️ [🛠️Define] {cname}.{fname}属性设置为unique时，index不能设置为False。"
msgstr ""
"⚠️ [🛠️Define] Wenn die Eigenschaft {cname}.{fname} auf unique gesetzt "
"ist, darf index nicht auf False gesetzt werden."

#: hetu/data/component.py:401
#, python-brace-format
msgid ""
"{cname}.{fname}默认值不能为None。所有属性都要有默认值，因为数据接口统一用c like "
"struct实现，强类型struct不接受NULL/None值。"
msgstr ""
"Der Standardwert für {cname}.{fname} darf nicht None sein. Alle "
"Eigenschaften müssen einen Standardwert haben, da die Datenschnittstelle "
"einheitlich als C-ähnliches Struct implementiert ist. Stark typisierte "
"Structs akzeptieren keine NULL/None-Werte."

#: hetu/data/component.py:412
#, python-brace-format
msgid "{cname}.{fname}的default值：{default_type}({default_value})和属性dtype({dtype})不匹配"
msgstr ""
"Der Standardwert für {cname}.{fname}: {default_type}({default_value}) "
"stimmt nicht mit dem Eigenschafts-dtype({dtype}) überein."

#: hetu/data/component.py:426
#, python-brace-format
msgid "{cname}权限为OWNER时，不能设置rls_compare参数"
msgstr ""
"Wenn die Berechtigung für {cname} OWNER ist, darf der rls_compare-"
"Parameter nicht gesetzt werden."

#: hetu/data/component.py:429
#, python-brace-format
msgid "{cname}权限为OWNER时，必须有owner属性"
msgstr ""
"Wenn die Berechtigung für {cname} OWNER ist, muss eine owner-Eigenschaft "
"vorhanden sein."

#: hetu/data/component.py:436
#, python-brace-format
msgid "{cname}的owner属性必需是numeric数字(int, np.int64, ...)类型"
msgstr ""
"Die owner-Eigenschaft von {cname} muss vom numerischen Typ (int, "
"np.int64, ...) sein."

#: hetu/data/component.py:442
#, python-brace-format
msgid "{cname}权限为RLS时，必须通过rls_compare参数定义行级权限逻辑"
msgstr ""
"Wenn die Berechtigung für {cname} RLS ist, muss die Zeilenebenen-"
"Berechtigungslogik über den rls_compare-Parameter definiert werden."

#: hetu/data/component.py:445
#, python-brace-format
msgid "{cname}.rls_compare参数必须全部是字符串类型"
msgstr "Alle rls_compare-Parameter von {cname} müssen vom Typ String sein."

#: hetu/data/component.py:448
#, python-brace-format
msgid "{cname}.rls_compare参数必须只有3个元素)"
msgstr "Der rls_compare-Parameter von {cname} muss genau 3 Elemente haben."

#: hetu/data/component.py:452
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但operator模块没有{method}方法"
msgstr ""
"Berechtigung für {cname} ist RLS: {rls_compare}, aber das operator-Modul "
"hat keine Methode {method}."

#: hetu/data/component.py:456
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但表没有定义{prop}属性"
msgstr ""
"Berechtigung für {cname} ist RLS: {rls_compare}, aber die Tabelle hat "
"keine Eigenschaft {prop} definiert."

#: hetu/data/component.py:463
#, python-brace-format
msgid "组件名({name})是C#关键字，请refactor。"
msgstr ""
"Der Komponentenname ({name}) ist ein C#-Schlüsselwort, bitte "
"refaktorisieren."

#: hetu/data/component.py:476
#, python-brace-format
msgid "{cls_name}.{name}不是Property类型"
msgstr "{cls_name}.{name} ist nicht vom Typ Property."

#: hetu/data/component.py:486
#, python-brace-format
msgid "{cls_name}.{name}属性未定义type hint。请使用以下形式，{name}: type = property_field(...)"
msgstr ""
"Die Eigenschaft {cls_name}.{name} hat keinen Type-Hint definiert. Bitte "
"verwenden Sie die Form: {name}: type = property_field(...)"

#: hetu/data/component.py:491
#, python-brace-format
msgid "{cls_name}至少要有1个Property成员"
msgstr "{cls_name} muss mindestens 1 Property-Mitglied haben."

#: hetu/data/component.py:497
#, python-brace-format
msgid "{cls_name}.id是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}.id ist ein reservierter, interner Primärschlüssel und kann "
"extern nicht neu definiert werden."

#: hetu/data/component.py:500
#, python-brace-format
msgid "{cls_name}._version是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}._version ist ein reservierter, interner Primärschlüssel und "
"kann extern nicht neu definiert werden."

#: hetu/data/component.py:509
#, python-brace-format
msgid "{cls_name}必须继承于BaseComponent"
msgstr "{cls_name} muss von BaseComponent erben."

#: hetu/data/migration.py:39
#, python-brace-format
msgid "  ➖ [💾Redis][{comp_name}组件] 发现自定义迁移脚本 {file}，将调用脚本进行迁移..."
msgstr ""
"  ➖ [💾Redis][{comp_name} Komponente] Benutzerdefiniertes Migrationsskript"
" {file} gefunden, Skript wird für Migration aufgerufen..."

#: hetu/data/migration.py:88
#, python-brace-format
msgid ""
"  ➖ [💾Redis][{comp_name}组件] 缺少迁移脚本，生成默认迁移脚本 "
"{script_path}，请根据需要修改脚本内容后再执行迁移操作..."
msgstr ""
"  ➖ [💾Redis][{comp_name} Komponente] Migrationsskript fehlt, Standard-"
"Migrationsskript {script_path} generiert. Bitte Skriptinhalt nach Bedarf "
"anpassen, bevor die Migration ausgeführt wird..."

#: hetu/data/migration.py:200
#, python-brace-format
msgid "  ➖ [💾Redis][{comp_name}组件] 执行upgrade迁移：{module}"
msgstr "  ➖ [💾Redis][{comp_name} Komponente] Upgrade-Migration ausführen: {module}"

#: hetu/data/migration.py:207
#, python-brace-format
msgid "  ✔️ [💾Redis][{comp_name}组件] Schema升级迁移完成，共处理{count}行"
msgstr ""
"  ✔️ [💾Redis][{comp_name} Komponente] Schema-Upgrade-Migration "
"abgeschlossen, insgesamt {count} Zeilen verarbeitet"

#: hetu/data/migration.py:212
#, python-brace-format
msgid "  ✔️ [💾Redis][{comp_name}组件] 已重建Index"
msgstr "  ✔️ [💾Redis][{comp_name} Komponente] Index wurde neu aufgebaut"

#: hetu/data/sub.py:179
#, python-brace-format
msgid "IndexSubscription收到了未知的channel消息: {channel}"
msgstr "IndexSubscription hat eine unbekannte Kanalnachricht erhalten: {channel}"

#: hetu/data/sub.py:294 hetu/data/sub.py:385
#, python-brace-format
msgid "⚠️ [📡Subscription] {sub_id} 数据重复订阅，检查客户端代码"
msgstr ""
"⚠️ [📡Subscription] {sub_id} Datenabonnement dupliziert, Client-Code "
"überprüfen"

#: hetu/data/sub.py:303
#, python-brace-format
msgid "🆕 [📡Subscription] 订阅了行: {sub_id} {channel_name}"
msgstr "🆕 [📡Subscription] Zeile abonniert: {sub_id} {channel_name}"

#: hetu/data/sub.py:359
#, python-brace-format
msgid "⚠️ [📡Subscription] {comp_name}无调用权限，检查是否非法调用，caller：{caller}"
msgstr ""
"⚠️ [📡Subscription] {comp_name} hat keine Aufrufberechtigung, auf illegale"
" Aufrufe prüfen, Aufrufer: {caller}"

#: hetu/data/sub.py:394
