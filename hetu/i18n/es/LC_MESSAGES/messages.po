#: hetu/manager.py:56
#, python-brace-format
msgid "Backend {backend}未找到"
msgstr "Backend {backend} no encontrado"

#: hetu/manager.py:100
#, python-brace-format
msgid "⚠️  组件 {comp_name} 的表结构需要迁移Schema。"
msgstr "⚠️  El esquema de la tabla del componente {comp_name} necesita migración."

#: hetu/manager.py:107
#, python-brace-format
msgid "⚠️  组件 {comp_name} 的表需要迁移到新集群。"
msgstr "⚠️  La tabla del componente {comp_name} necesita migrar al nuevo clúster."

#: hetu/cli/__init__.py:25
msgid "河图数据库"
msgstr "Base de datos de Hetu"

#: hetu/cli/__init__.py:29
msgid "执行操作"
msgstr "Ejecutar operación"

#: hetu/cli/base.py:21
msgid "Boolean value expected."
msgstr "Se esperaba un valor booleano."

#: hetu/cli/build.py:22
msgid "生成客户端SDK C# 类型代码"
msgstr "Generar código de tipos C# para el SDK del cliente"

#: hetu/cli/build.py:26 hetu/cli/migrate.py:46 hetu/cli/start.py:82
msgid "河图app的py文件"
msgstr "Archivo Python de la aplicación Hetu"

#: hetu/cli/build.py:33
msgid "编译app.py中哪个namespace下的数据类型"
msgstr "Qué namespace en app.py compilar para los tipos de datos"

#: hetu/cli/build.py:37
msgid "输出文件路径"
msgstr "Ruta del archivo de salida"

#: hetu/cli/build.py:46 hetu/cli/migrate.py:92
#, python-brace-format
msgid "无法加载app文件 {app_file}"
msgstr "No se pudo cargar el archivo de aplicación {app_file}"

#: hetu/cli/build.py:59
#, python-brace-format
msgid "✅ 已生成C#代码到 {output}"
msgstr "✅ Código C# generado en {output}"

#: hetu/cli/migrate.py:34
msgid "在数据库执行Schema升级脚本,如果没有则创建，如果无变更则跳过。同时还会进行临时表的清空。应该在CI/CD流程中，每次启动服务器前执行一次。"
msgstr ""
"Ejecuta los scripts de actualización del esquema en la base de datos. Si "
"no existen, los crea; si no hay cambios, los omite. También limpia las "
"tablas temporales. Debe ejecutarse una vez antes de cada inicio del "
"servidor en el flujo de CI/CD."

#: hetu/cli/migrate.py:41 hetu/cli/start.py:100
msgid "后端数据库地址"
msgstr "Dirección de la base de datos backend"

#: hetu/cli/migrate.py:51 hetu/cli/start.py:89
msgid "启动app.py中哪个namespace下的System"
msgstr "Qué System bajo qué namespace iniciar en app.py"

#: hetu/cli/migrate.py:54 hetu/cli/start.py:92
msgid "实例名称，每个实例是一个副本"
msgstr "Nombre de la instancia, cada instancia es una réplica"

#: hetu/cli/migrate.py:58
msgid "通过yml配置文件读取后端数据库地址"
msgstr ""
"Lee la dirección de la base de datos backend desde un archivo de "
"configuración YAML."

#: hetu/cli/migrate.py:64
msgid "自动确认数据备份提示"
msgstr "Confirmar automáticamente el aviso de copia de seguridad de datos."

#: hetu/cli/migrate.py:70
msgid "强制执行升级迁移，丢弃无法迁移的数据。请勿在生产环境使用此选项！"
msgstr ""
"Forzar la migración de actualización, descartando datos que no se puedan "
"migrar. ¡No uses esta opción en entornos de producción!"

#: hetu/cli/migrate.py:104
msgid "⚠️  升级数据库表结构可能会导致数据丢失，请确保已备份数据。确认继续请输 y ，取消请输其他键然后回车："
msgstr ""
"⚠️  Actualizar la estructura de las tablas de la base de datos puede "
"causar pérdida de datos. Asegúrate de tener una copia de seguridad. Para "
"confirmar y continuar, escribe 'y'; para cancelar, escribe cualquier otra"
" tecla y presiona Enter:"

#: hetu/cli/migrate.py:109 hetu/cli/migrate.py:136
msgid "❌  升级迁移已取消。"
msgstr "❌  Migración de actualización cancelada."

#: hetu/cli/migrate.py:126
msgid "❗ Component有数据删除或类型变更，请修改自动生成的迁移脚本，手动处理这些属性。或使用--drop-data参数直接丢弃这些属性。"
msgstr ""
"❗ Hay eliminación de datos o cambios de tipo en Component. Modifica el "
"script de migración generado automáticamente para manejar estos atributos"
" manualmente. O usa el parámetro --drop-data para descartar estos "
"atributos directamente."

#: hetu/cli/migrate.py:133
msgid "⚠️  确认强制迁移请输 y ，取消请输其他键然后回车："
msgstr ""
"⚠️  Para confirmar la migración forzada, escribe 'y'; para cancelar, "
"escribe cualquier otra tecla y presiona Enter:"

#: hetu/cli/migrate.py:139
#, python-brace-format
msgid "⚠️  正在强制迁移 {instance_name} 服所有表结构，可能会丢失数据..."
msgstr ""
"⚠️  Forzando la migración de todas las estructuras de tabla para la "
"instancia {instance_name}. Puede haber pérdida de datos..."

#: hetu/cli/migrate.py:147
#, python-brace-format
msgid "🧹 正在清除 {instance_name} 服易失数据..."
msgstr "🧹 Limpiando datos volátiles para la instancia {instance_name}..."

#: hetu/cli/migrate.py:150
#, python-brace-format
msgid "✅  {instance_name} 服升级迁移完成！"
msgstr ""
"✅  ¡Migración de actualización completada para la instancia "
"{instance_name}!"

#: hetu/cli/migrate.py:151
msgid "🎉  恭喜！所有数据库表结构均已升级完成！"
msgstr ""
"🎉  ¡Felicidades! Todas las estructuras de tabla de la base de datos han "
"sido actualizadas."

#: hetu/cli/migrate.py:173
msgid "namespace参数不能为空，建议用--config参数"
msgstr ""
"El parámetro namespace no puede estar vacío. Se recomienda usar el "
"parámetro --config."

#: hetu/cli/migrate.py:174
msgid "instance参数不能为空，建议用--config参数"
msgstr ""
"El parámetro instance no puede estar vacío. Se recomienda usar el "
"parámetro --config."

#: hetu/cli/migrate.py:175
msgid "app_file参数不能为空，建议用--config参数"
msgstr ""
"El parámetro app_file no puede estar vacío. Se recomienda usar el "
"parámetro --config."

#: hetu/cli/start.py:52
#, python-brace-format
msgid ""
"不支持的数据库URL scheme: '{scheme}'。目前支持 "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"
msgstr ""
"Esquema de URL de base de datos no soportado: '{scheme}'. Actualmente se "
"soportan "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"

#: hetu/cli/start.py:77
msgid "启动河图服务"
msgstr "Iniciar el servicio Hetu"

#: hetu/cli/start.py:79
msgid "通过命令行启动参数"
msgstr "A través de parámetros de línea de comandos"

#: hetu/cli/start.py:95
msgid "监听的Websocket端口"
msgstr "Puerto Websocket para escuchar"

#: hetu/cli/start.py:104
msgid "工作进程数，可设为 CPU * 1.2"
msgstr "Número de procesos de trabajo, se puede establecer como CPU * 1.2"

#: hetu/cli/start.py:112
msgid "开启debug模式，这会启动代码热更新，并显示更多的log信息。如果设置为2，则对框架内核也启用debug模式，会开启Python协程的Debug模式，速度慢90％。"
msgstr ""
"Activar modo debug, esto iniciará la recarga en caliente de código y "
"mostrará más información de log. Si se establece en 2, también se activa "
"el modo debug para el núcleo del framework, lo que habilita el modo Debug"
" de las corrutinas de Python, reduciendo la velocidad en un 90%."

#: hetu/cli/start.py:122
msgid "证书目录，如果不设置则使用不安全的连接。不建议这里设置，请外加一层反向https代理。填入auto会生成自签https证书。"
msgstr ""
"Directorio de certificados, si no se establece se usa una conexión "
"insegura. No se recomienda configurarlo aquí, añade una capa de proxy "
"inverso https externo. Escribir 'auto' generará un certificado https "
"autofirmado."

#: hetu/cli/start.py:130
msgid "默认crypto层的auth_key，用于握手签名校验。留空则不启用。"
msgstr ""
"Clave de autenticación predeterminada de la capa crypto, para "
"verificación de firma en el handshake. Déjalo vacío para desactivar."

#: hetu/cli/start.py:137
msgid "配置文件模板见CONFIG_TEMPLATE.yml"
msgstr "La plantilla del archivo de configuración está en CONFIG_TEMPLATE.yml"

#: hetu/cli/start.py:155
msgid "--app_file是必须参数，或者用--config"
msgstr "--app_file es un parámetro obligatorio, o usa --config"

#: hetu/cli/start.py:158
msgid "--namespace是必须参数，或者用--config"
msgstr "--namespace es un parámetro obligatorio, o usa --config"

#: hetu/cli/start.py:161
msgid "--instance是必须参数，或者用--config"
msgstr "--instance es un parámetro obligatorio, o usa --config"

#: hetu/cli/start.py:218
#, python-brace-format
msgid "ℹ️ {name}, {mode}, {workers} 个工作进程, 管理进程 pid: {pid}"
msgstr ""
"ℹ️ {name}, {mode}, {workers} procesos de trabajo, pid del proceso de "
"gestión: {pid}"

#: hetu/cli/start.py:226
#, python-brace-format
msgid "ℹ️ Python {version} 平台 {platform}"
msgstr "ℹ️ Python {version} plataforma {platform}"

#: hetu/cli/start.py:231
#, python-brace-format
msgid "📡 监听地址： http{s}://{host}:{port}"
msgstr "📡 Dirección de escucha: http{s}://{host}:{port}"

#: hetu/cli/start.py:237
#, python-brace-format
msgid "ℹ️ 消息流协议：json -> {layers} -> Network"
msgstr "ℹ️ Protocolo de flujo de mensajes: json -> {layers} -> Network"

#: hetu/cli/start.py:244
msgid "⚠️⚠️⚠️ 深度Debug模式开启  ⚠️⚠️⚠️   此模式下Python协程慢90%"
msgstr ""
"⚠️⚠️⚠️ Modo Debug profundo activado  ⚠️⚠️⚠️   Las corrutinas de Python "
"son un 90% más lentas en este modo"

#: hetu/common/slowlog.py:72
#, python-brace-format
msgid ""
"⚠️ [📞慢日志] 系统 {name} 执行时间 {elapsed}秒，事务冲突次数 {retry}，平均时间 {avg_time}秒\n"
"{table}"
msgstr ""
"⚠️ [📞 Registro lento] El sistema {name} tardó {elapsed} segundos en "
"ejecutarse, con {retry} conflictos de transacción, tiempo promedio "
"{avg_time} segundos\n"
"{table}"

#: hetu/common/slowlog.py:99
msgid "系统"
msgstr "Sistema"

#: hetu/common/slowlog.py:99
msgid "平均时间"
msgstr "Tiempo promedio"

#: hetu/common/slowlog.py:99
msgid "平均冲突次数"
msgstr "Promedio de conflictos"

#: hetu/common/snowflake_id.py:84
#, python-brace-format
msgid "Worker ID不能大于{max}或小于0"
msgstr "El ID de trabajador no puede ser mayor que {max} o menor que 0"

#: hetu/common/snowflake_id.py:98
#, python-brace-format
msgid "[❄️ID] 雪花ID生成器初始化完成，Worker ID: {worker_id}, last_timestamp: {ts}"
msgstr ""
"[❄️ID] Generador de ID de Snowflake inicializado, ID de trabajador: "
"{worker_id}, last_timestamp: {ts}"

#: hetu/common/snowflake_id.py:110
msgid "SnowflakeID 未初始化，请先调用 init() 方法。"
msgstr ""
"SnowflakeID no está inicializado, por favor llama primero al método "
"init()."

#: hetu/common/snowflake_id.py:119
#, python-brace-format
msgid "[❄️ID] 时钟回拨了 {ms} 毫秒。"
msgstr "[❄️ID] El reloj retrocedió {ms} milisegundos."

#: hetu/common/snowflake_id.py:154 hetu/common/snowflake_id.py:170
msgid "[❄️ID] 每毫秒只能生成有限的ID，需要休眠 1 ms"
msgstr ""
"[❄️ID] Solo se pueden generar un número limitado de IDs por milisegundo, "
"es necesario dormir 1 ms"

#: hetu/data/component.py:253
msgid "Component重复定义"
msgstr "Definición duplicada de Component"

#: hetu/data/component.py:369
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是Python关键字。"
msgstr ""
"Error en la definición de la propiedad {cname}.{fname}, el nombre de la "
"propiedad no puede ser una palabra clave de Python."

#: hetu/data/component.py:375
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是C#关键字。"
msgstr ""
"Error en la definición de la propiedad {cname}.{fname}, el nombre de la "
"propiedad no puede ser una palabra clave de C#."

#: hetu/data/component.py:381
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不能为0长度。str类型请用'<U8'方式定义"
msgstr ""
"El dtype de la propiedad {cname}.{fname} no puede tener longitud 0. Para "
"el tipo str, defínalo usando el formato '<U8'."

#: hetu/data/component.py:384
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不支持void类型"
msgstr "El dtype de la propiedad {cname}.{fname} no admite el tipo void."

#: hetu/data/component.py:394
#, python-brace-format
msgid "⚠️ [🛠️Define] {cname}.{fname}属性设置为unique时，index不能设置为False。"
msgstr ""
"⚠️ [🛠️Define] Cuando la propiedad {cname}.{fname} se establece como "
"unique, index no puede establecerse en False."

#: hetu/data/component.py:401
#, python-brace-format
msgid ""
"{cname}.{fname}默认值不能为None。所有属性都要有默认值，因为数据接口统一用c like "
"struct实现，强类型struct不接受NULL/None值。"
msgstr ""
"El valor por defecto de {cname}.{fname} no puede ser None. Todas las "
"propiedades deben tener un valor por defecto, ya que la interfaz de datos"
" se implementa de manera unificada con estructuras similares a C, y las "
"estructuras fuertemente tipadas no aceptan valores NULL/None."

#: hetu/data/component.py:412
#, python-brace-format
msgid "{cname}.{fname}的default值：{default_type}({default_value})和属性dtype({dtype})不匹配"
msgstr ""
"El valor por defecto de {cname}.{fname}: {default_type}({default_value}) "
"no coincide con el dtype de la propiedad ({dtype})"

#: hetu/data/component.py:426
#, python-brace-format
msgid "{cname}权限为OWNER时，不能设置rls_compare参数"
msgstr ""
"Cuando el permiso de {cname} es OWNER, no se puede establecer el "
"parámetro rls_compare."

#: hetu/data/component.py:429
#, python-brace-format
msgid "{cname}权限为OWNER时，必须有owner属性"
msgstr "Cuando el permiso de {cname} es OWNER, debe tener una propiedad owner."

#: hetu/data/component.py:436
#, python-brace-format
msgid "{cname}的owner属性必需是numeric数字(int, np.int64, ...)类型"
msgstr ""
"La propiedad owner de {cname} debe ser de tipo numérico (int, np.int64, "
"...)."

#: hetu/data/component.py:442
#, python-brace-format
msgid "{cname}权限为RLS时，必须通过rls_compare参数定义行级权限逻辑"
msgstr ""
"Cuando el permiso de {cname} es RLS, se debe definir la lógica de "
"permisos a nivel de fila mediante el parámetro rls_compare."

#: hetu/data/component.py:445
#, python-brace-format
msgid "{cname}.rls_compare参数必须全部是字符串类型"
msgstr "El parámetro rls_compare de {cname} debe ser completamente de tipo string."

#: hetu/data/component.py:448
#, python-brace-format
msgid "{cname}.rls_compare参数必须只有3个元素)"
msgstr "El parámetro rls_compare de {cname} debe tener exactamente 3 elementos."

#: hetu/data/component.py:452
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但operator模块没有{method}方法"
msgstr ""
"Permiso de {cname} es RLS: {rls_compare}, pero el módulo operator no "
"tiene el método {method}."

#: hetu/data/component.py:456
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但表没有定义{prop}属性"
msgstr ""
"Permiso de {cname} es RLS: {rls_compare}, pero la tabla no define la "
"propiedad {prop}."

#: hetu/data/component.py:463
#, python-brace-format
msgid "组件名({name})是C#关键字，请refactor。"
msgstr ""
"El nombre del componente ({name}) es una palabra clave de C#, por favor "
"refactorice."

#: hetu/data/component.py:476
#, python-brace-format
msgid "{cls_name}.{name}不是Property类型"
msgstr "{cls_name}.{name} no es del tipo Property."

#: hetu/data/component.py:486
#, python-brace-format
msgid "{cls_name}.{name}属性未定义type hint。请使用以下形式，{name}: type = property_field(...)"
msgstr ""
"La propiedad {cls_name}.{name} no tiene definida la anotación de tipo "
"(type hint). Por favor, use la siguiente forma: {name}: type = "
"property_field(...)"

#: hetu/data/component.py:491
#, python-brace-format
msgid "{cls_name}至少要有1个Property成员"
msgstr "{cls_name} debe tener al menos 1 miembro Property."

#: hetu/data/component.py:497
#, python-brace-format
msgid "{cls_name}.id是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}.id es una clave primaria interna reservada y no puede ser "
"redefinida externamente."

#: hetu/data/component.py:500
#, python-brace-format
msgid "{cls_name}._version是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}._version es una clave primaria interna reservada y no puede "
"ser redefinida externamente."

#: hetu/data/component.py:509
#, python-brace-format
msgid "{cls_name}必须继承于BaseComponent"
msgstr "{cls_name} debe heredar de BaseComponent."

#: hetu/data/migration.py:39
#, python-brace-format
msgid "  ➖ [💾Redis][{comp_name}组件] 发现自定义迁移脚本 {file}，将调用脚本进行迁移..."
msgstr ""
"  ➖ [💾Redis][Componente {comp_name}] Se ha encontrado el script de "
"migración personalizado {file}, se invocará el script para la "
"migración..."

#: hetu/data/migration.py:88
#, python-brace-format
msgid ""
"  ➖ [💾Redis][{comp_name}组件] 缺少迁移脚本，生成默认迁移脚本 "
"{script_path}，请根据需要修改脚本内容后再执行迁移操作..."
msgstr ""
"  ➖ [💾Redis][Componente {comp_name}] Falta el script de migración, se ha "
"generado el script de migración predeterminado {script_path}. Por favor, "
"modifique el contenido del script según sea necesario antes de ejecutar "
"la operación de migración..."

#: hetu/data/migration.py:200
#, python-brace-format
msgid "  ➖ [💾Redis][{comp_name}组件] 执行upgrade迁移：{module}"
msgstr ""
"  ➖ [💾Redis][Componente {comp_name}] Ejecutando migración de "
"actualización (upgrade): {module}"

#: hetu/data/migration.py:207
#, python-brace-format
msgid "  ✔️ [💾Redis][{comp_name}组件] Schema升级迁移完成，共处理{count}行"
msgstr ""
"  ✔️ [💾Redis][Componente {comp_name}] Migración de actualización del "
"esquema completada, se procesaron {count} filas en total"

#: hetu/data/migration.py:212
#, python-brace-format
msgid "  ✔️ [💾Redis][{comp_name}组件] 已重建Index"
msgstr "  ✔️ [💾Redis][Componente {comp_name}] Índice reconstruido"

#: hetu/data/sub.py:179
#, python-brace-format
msgid "IndexSubscription收到了未知的channel消息: {channel}"
msgstr "IndexSubscription recibió un mensaje de canal desconocido: {channel}"

#: hetu/data/sub.py:294 hetu/data/sub.py:385
#, python-brace-format
msgid "⚠️ [📡Subscription] {sub_id} 数据重复订阅，检查客户端代码"
msgstr ""
"⚠️ [📡Subscription] {sub_id} suscripción duplicada de datos, revise el "
"código del cliente"

#: hetu/data/sub.py:303
#, python-brace-format
msgid "🆕 [📡Subscription] 订阅了行: {sub_id} {channel_name}"
msgstr "🆕 [📡Subscription] suscrito a fila: {sub_id} {channel_name}"

#: hetu/data/sub.py:359
#, python-brace-format
msgid "⚠️ [📡Subscription] {comp_name}无调用权限，检查是否非法调用，caller：{caller}"
msgstr ""
"⚠️ [📡Subscription] {comp_name} no tiene permisos de llamada, verifique si"
" es una llamada no autorizada, llamante: {caller}"

#: hetu/data/sub.py:394
#, python-brace-format
msgid "🆕 [📡Subscription] 订阅了索引: {sub_id} {index_channel}"
msgstr "🆕 [📡Subscription] suscrito a índice: {sub_id} {index_channel}"

