#: hetu/manager.py:56
#, python-brace-format
msgid "Backend {backend}未找到"
msgstr "Backend {backend} introuvable"

#: hetu/manager.py:100
#, python-brace-format
msgid "⚠️  组件 {comp_name} 的表结构需要迁移Schema。"
msgstr ""
"⚠️  Le schéma de la table du composant {comp_name} nécessite une "
"migration."

#: hetu/manager.py:107
#, python-brace-format
msgid "⚠️  组件 {comp_name} 的表需要迁移到新集群。"
msgstr ""
"⚠️  La table du composant {comp_name} doit être migrée vers le nouveau "
"cluster."

#: hetu/cli/__init__.py:25
msgid "河图数据库"
msgstr "Base de données Hetu"

#: hetu/cli/__init__.py:29
msgid "执行操作"
msgstr "Exécuter l'opération"

#: hetu/cli/base.py:21
msgid "Boolean value expected."
msgstr "Valeur booléenne attendue."

#: hetu/cli/build.py:22
msgid "生成客户端SDK C# 类型代码"
msgstr "Générer le code de type C# pour le SDK client"

#: hetu/cli/build.py:26 hetu/cli/migrate.py:46 hetu/cli/start.py:82
msgid "河图app的py文件"
msgstr "Fichier Python de l'application Hetu"

#: hetu/cli/build.py:33
msgid "编译app.py中哪个namespace下的数据类型"
msgstr "Compiler les types de données sous quel namespace dans app.py"

#: hetu/cli/build.py:37
msgid "输出文件路径"
msgstr "Chemin du fichier de sortie"

#: hetu/cli/build.py:46 hetu/cli/migrate.py:92
#, python-brace-format
msgid "无法加载app文件 {app_file}"
msgstr "Impossible de charger le fichier d'application {app_file}"

#: hetu/cli/build.py:59
#, python-brace-format
msgid "✅ 已生成C#代码到 {output}"
msgstr "✅ Code C# généré vers {output}"

#: hetu/cli/migrate.py:34
msgid "在数据库执行Schema升级脚本,如果没有则创建，如果无变更则跳过。同时还会进行临时表的清空。应该在CI/CD流程中，每次启动服务器前执行一次。"
msgstr ""
"Exécute les scripts de mise à niveau du schéma dans la base de données. "
"Les crée s'ils n'existent pas, les ignore s'il n'y a aucun changement. "
"Nettoie également les tables temporaires. Doit être exécuté une fois "
"avant chaque démarrage du serveur dans le pipeline CI/CD."

#: hetu/cli/migrate.py:41 hetu/cli/start.py:100
msgid "后端数据库地址"
msgstr "Adresse de la base de données backend"

#: hetu/cli/migrate.py:51 hetu/cli/start.py:89
msgid "启动app.py中哪个namespace下的System"
msgstr "Quel System sous quel namespace dans app.py doit être démarré"

#: hetu/cli/migrate.py:54 hetu/cli/start.py:92
msgid "实例名称，每个实例是一个副本"
msgstr "Nom de l'instance, chaque instance est une réplique"

#: hetu/cli/migrate.py:58
msgid "通过yml配置文件读取后端数据库地址"
msgstr ""
"Lit l'adresse de la base de données backend via le fichier de "
"configuration yml"

#: hetu/cli/migrate.py:64
msgid "自动确认数据备份提示"
msgstr "Confirme automatiquement l'invite de sauvegarde des données"

#: hetu/cli/migrate.py:70
msgid "强制执行升级迁移，丢弃无法迁移的数据。请勿在生产环境使用此选项！"
msgstr ""
"Force l'exécution de la migration de mise à niveau, en supprimant les "
"données non migrables. N'utilisez pas cette option en production !"

#: hetu/cli/migrate.py:104
msgid "⚠️  升级数据库表结构可能会导致数据丢失，请确保已备份数据。确认继续请输 y ，取消请输其他键然后回车："
msgstr ""
"⚠️  La mise à niveau de la structure des tables de la base de données "
"peut entraîner une perte de données. Assurez-vous d'avoir sauvegardé vos "
"données. Pour confirmer et continuer, tapez y, pour annuler, tapez toute "
"autre touche puis Entrée :"

#: hetu/cli/migrate.py:109 hetu/cli/migrate.py:136
msgid "❌  升级迁移已取消。"
msgstr "❌  La migration de mise à niveau a été annulée."

#: hetu/cli/migrate.py:126
msgid "❗ Component有数据删除或类型变更，请修改自动生成的迁移脚本，手动处理这些属性。或使用--drop-data参数直接丢弃这些属性。"
msgstr ""
"❗ Des données de Component ont été supprimées ou leur type a changé. "
"Veuillez modifier le script de migration généré automatiquement pour "
"traiter manuellement ces attributs. Ou utilisez le paramètre --drop-data "
"pour supprimer directement ces attributs."

#: hetu/cli/migrate.py:133
msgid "⚠️  确认强制迁移请输 y ，取消请输其他键然后回车："
msgstr ""
"⚠️  Pour confirmer la migration forcée, tapez y, pour annuler, tapez "
"toute autre touche puis Entrée :"

#: hetu/cli/migrate.py:139
#, python-brace-format
msgid "⚠️  正在强制迁移 {instance_name} 服所有表结构，可能会丢失数据..."
msgstr ""
"⚠️  Migration forcée en cours de toutes les structures de table pour le "
"serveur {instance_name}. Des données peuvent être perdues..."

#: hetu/cli/migrate.py:147
#, python-brace-format
msgid "🧹 正在清除 {instance_name} 服易失数据..."
msgstr "🧹 Nettoyage des données volatiles pour le serveur {instance_name}..."

#: hetu/cli/migrate.py:150
#, python-brace-format
msgid "✅  {instance_name} 服升级迁移完成！"
msgstr "✅  Migration de mise à niveau terminée pour le serveur {instance_name} !"

#: hetu/cli/migrate.py:151
msgid "🎉  恭喜！所有数据库表结构均已升级完成！"
msgstr ""
"🎉  Félicitations ! Toutes les structures de table de la base de données "
"ont été mises à niveau !"

#: hetu/cli/migrate.py:173
msgid "namespace参数不能为空，建议用--config参数"
msgstr ""
"Le paramètre namespace ne peut pas être vide. Il est recommandé "
"d'utiliser le paramètre --config."

#: hetu/cli/migrate.py:174
msgid "instance参数不能为空，建议用--config参数"
msgstr ""
"Le paramètre instance ne peut pas être vide. Il est recommandé d'utiliser"
" le paramètre --config."

#: hetu/cli/migrate.py:175
msgid "app_file参数不能为空，建议用--config参数"
msgstr ""
"Le paramètre app_file ne peut pas être vide. Il est recommandé d'utiliser"
" le paramètre --config."

#: hetu/cli/start.py:52
#, python-brace-format
msgid ""
"不支持的数据库URL scheme: '{scheme}'。目前支持 "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"
msgstr ""
"Schéma d'URL de base de données non pris en charge : '{scheme}'. "
"Actuellement pris en charge : "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"

#: hetu/cli/start.py:77
msgid "启动河图服务"
msgstr "Démarrer le service Hetu"

#: hetu/cli/start.py:79
msgid "通过命令行启动参数"
msgstr "Paramètres de démarrage via la ligne de commande"

#: hetu/cli/start.py:95
msgid "监听的Websocket端口"
msgstr "Port Websocket à écouter"

#: hetu/cli/start.py:104
msgid "工作进程数，可设为 CPU * 1.2"
msgstr "Nombre de processus de travail, peut être défini sur CPU * 1.2"

#: hetu/cli/start.py:112
msgid "开启debug模式，这会启动代码热更新，并显示更多的log信息。如果设置为2，则对框架内核也启用debug模式，会开启Python协程的Debug模式，速度慢90％。"
msgstr ""
"Activer le mode debug, ce qui lance le rechargement à chaud du code et "
"affiche plus d'informations de log. Si défini à 2, le mode debug est "
"également activé pour le noyau du framework, ce qui active le mode Debug "
"des coroutines Python, ralentissant de 90 %."

#: hetu/cli/start.py:122
msgid "证书目录，如果不设置则使用不安全的连接。不建议这里设置，请外加一层反向https代理。填入auto会生成自签https证书。"
msgstr ""
"Répertoire des certificats, si non défini, une connexion non sécurisée "
"est utilisée. Il n'est pas recommandé de le définir ici, veuillez ajouter"
" une couche de proxy HTTPS inverse. Entrer 'auto' générera un certificat "
"HTTPS auto-signé."

#: hetu/cli/start.py:130
msgid "默认crypto层的auth_key，用于握手签名校验。留空则不启用。"
msgstr ""
"Clé d'authentification par défaut de la couche crypto, utilisée pour la "
"vérification de signature lors du handshake. Laisser vide pour "
"désactiver."

#: hetu/cli/start.py:137
msgid "配置文件模板见CONFIG_TEMPLATE.yml"
msgstr "Voir CONFIG_TEMPLATE.yml pour le modèle de fichier de configuration"

#: hetu/cli/start.py:155
msgid "--app_file是必须参数，或者用--config"
msgstr "--app_file est un paramètre obligatoire, ou utilisez --config"

#: hetu/cli/start.py:158
msgid "--namespace是必须参数，或者用--config"
msgstr "--namespace est un paramètre obligatoire, ou utilisez --config"

#: hetu/cli/start.py:161
msgid "--instance是必须参数，或者用--config"
msgstr "--instance est un paramètre obligatoire, ou utilisez --config"

#: hetu/cli/start.py:218
#, python-brace-format
msgid "ℹ️ {name}, {mode}, {workers} 个工作进程, 管理进程 pid: {pid}"
msgstr ""
"ℹ️ {name}, {mode}, {workers} processus de travail, pid du processus de "
"gestion : {pid}"

#: hetu/cli/start.py:226
#, python-brace-format
msgid "ℹ️ Python {version} 平台 {platform}"
msgstr "ℹ️ Python {version} plateforme {platform}"

#: hetu/cli/start.py:231
#, python-brace-format
msgid "📡 监听地址： http{s}://{host}:{port}"
msgstr "📡 Adresse d'écoute : http{s}://{host}:{port}"

#: hetu/cli/start.py:237
#, python-brace-format
msgid "ℹ️ 消息流协议：json -> {layers} -> Network"
msgstr "ℹ️ Protocole de flux de messages : json -> {layers} -> Network"

#: hetu/cli/start.py:244
msgid "⚠️⚠️⚠️ 深度Debug模式开启  ⚠️⚠️⚠️   此模式下Python协程慢90%"
msgstr ""
"⚠️⚠️⚠️ Mode Debug profond activé  ⚠️⚠️⚠️   Les coroutines Python sont 90%"
" plus lentes dans ce mode"

#: hetu/common/slowlog.py:72
#, python-brace-format
msgid ""
"⚠️ [📞慢日志] 系统 {name} 执行时间 {elapsed}秒，事务冲突次数 {retry}，平均时间 {avg_time}秒\n"
"{table}"
msgstr ""
"⚠️ [📞 Journal des opérations lentes] Le système {name} a mis {elapsed} "
"secondes, conflits de transaction {retry}, temps moyen {avg_time} "
"secondes\n"
"{table}"

#: hetu/common/slowlog.py:99
msgid "系统"
msgstr "Système"

#: hetu/common/slowlog.py:99
msgid "平均时间"
msgstr "Temps moyen"

#: hetu/common/slowlog.py:99
msgid "平均冲突次数"
msgstr "Nombre moyen de conflits"

#: hetu/common/snowflake_id.py:84
#, python-brace-format
msgid "Worker ID不能大于{max}或小于0"
msgstr "L'ID du worker ne peut pas être supérieur à {max} ou inférieur à 0"

#: hetu/common/snowflake_id.py:98
#, python-brace-format
msgid "[❄️ID] 雪花ID生成器初始化完成，Worker ID: {worker_id}, last_timestamp: {ts}"
msgstr ""
"[❄️ID] Générateur d'ID Snowflake initialisé, Worker ID : {worker_id}, "
"last_timestamp : {ts}"

#: hetu/common/snowflake_id.py:110
msgid "SnowflakeID 未初始化，请先调用 init() 方法。"
msgstr ""
"SnowflakeID n'est pas initialisé, veuillez d'abord appeler la méthode "
"init()."

#: hetu/common/snowflake_id.py:119
#, python-brace-format
msgid "[❄️ID] 时钟回拨了 {ms} 毫秒。"
msgstr "[❄️ID] L'horloge a reculé de {ms} millisecondes."

#: hetu/common/snowflake_id.py:154 hetu/common/snowflake_id.py:170
msgid "[❄️ID] 每毫秒只能生成有限的ID，需要休眠 1 ms"
msgstr ""
"[❄️ID] Seul un nombre limité d'ID peut être généré par milliseconde, une "
"pause de 1 ms est nécessaire"

#: hetu/data/component.py:253
msgid "Component重复定义"
msgstr "Définition en double du composant"

#: hetu/data/component.py:369
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是Python关键字。"
msgstr ""
"Erreur de définition de l'attribut {cname}.{fname} : le nom de l'attribut"
" ne peut pas être un mot-clé Python."

#: hetu/data/component.py:375
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是C#关键字。"
msgstr ""
"Erreur de définition de l'attribut {cname}.{fname} : le nom de l'attribut"
" ne peut pas être un mot-clé C#."

#: hetu/data/component.py:381
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不能为0长度。str类型请用'<U8'方式定义"
msgstr ""
"Le dtype de l'attribut {cname}.{fname} ne peut pas avoir une longueur de "
"0. Pour le type str, veuillez utiliser la définition '<U8'."

#: hetu/data/component.py:384
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不支持void类型"
msgstr ""
"Le dtype de l'attribut {cname}.{fname} ne prend pas en charge le type "
"void."

#: hetu/data/component.py:394
#, python-brace-format
msgid "⚠️ [🛠️Define] {cname}.{fname}属性设置为unique时，index不能设置为False。"
msgstr ""
"⚠️ [🛠️Define] Lorsque l'attribut {cname}.{fname} est défini comme unique,"
" index ne peut pas être défini sur False."

#: hetu/data/component.py:401
#, python-brace-format
msgid ""
"{cname}.{fname}默认值不能为None。所有属性都要有默认值，因为数据接口统一用c like "
"struct实现，强类型struct不接受NULL/None值。"
msgstr ""
"La valeur par défaut de {cname}.{fname} ne peut pas être None. Tous les "
"attributs doivent avoir une valeur par défaut, car l'interface de données"
" est implémentée de manière unifiée avec des struct de type C ; un struct"
" fortement typé n'accepte pas les valeurs NULL/None."

#: hetu/data/component.py:412
#, python-brace-format
msgid "{cname}.{fname}的default值：{default_type}({default_value})和属性dtype({dtype})不匹配"
msgstr ""
"La valeur par défaut de {cname}.{fname} : {default_type}({default_value})"
" ne correspond pas au dtype de l'attribut ({dtype})."

#: hetu/data/component.py:426
#, python-brace-format
msgid "{cname}权限为OWNER时，不能设置rls_compare参数"
msgstr ""
"Lorsque la permission de {cname} est OWNER, le paramètre rls_compare ne "
"peut pas être défini."

#: hetu/data/component.py:429
#, python-brace-format
msgid "{cname}权限为OWNER时，必须有owner属性"
msgstr ""
"Lorsque la permission de {cname} est OWNER, il doit y avoir un attribut "
"owner."

#: hetu/data/component.py:436
#, python-brace-format
msgid "{cname}的owner属性必需是numeric数字(int, np.int64, ...)类型"
msgstr ""
"L'attribut owner de {cname} doit être de type numérique (int, np.int64, "
"...)."

#: hetu/data/component.py:442
#, python-brace-format
msgid "{cname}权限为RLS时，必须通过rls_compare参数定义行级权限逻辑"
msgstr ""
"Lorsque la permission de {cname} est RLS, la logique de permission au "
"niveau des lignes doit être définie via le paramètre rls_compare."

#: hetu/data/component.py:445
#, python-brace-format
msgid "{cname}.rls_compare参数必须全部是字符串类型"
msgstr ""
"Le paramètre rls_compare de {cname} doit être entièrement de type chaîne "
"de caractères."

#: hetu/data/component.py:448
#, python-brace-format
msgid "{cname}.rls_compare参数必须只有3个元素)"
msgstr "Le paramètre rls_compare de {cname} doit avoir exactement 3 éléments."

#: hetu/data/component.py:452
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但operator模块没有{method}方法"
msgstr ""
"Permission de {cname} est RLS : {rls_compare}, mais le module operator "
"n'a pas de méthode {method}."

#: hetu/data/component.py:456
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但表没有定义{prop}属性"
msgstr ""
"Permission de {cname} est RLS : {rls_compare}, mais la table n'a pas "
"défini l'attribut {prop}."

#: hetu/data/component.py:463
#, python-brace-format
msgid "组件名({name})是C#关键字，请refactor。"
msgstr "Le nom du composant ({name}) est un mot-clé C#, veuillez le refactoriser."

#: hetu/data/component.py:476
#, python-brace-format
msgid "{cls_name}.{name}不是Property类型"
msgstr "{cls_name}.{name} n'est pas de type Property."

#: hetu/data/component.py:486
#, python-brace-format
msgid "{cls_name}.{name}属性未定义type hint。请使用以下形式，{name}: type = property_field(...)"
msgstr ""
"L'attribut {cls_name}.{name} n'a pas de type hint défini. Veuillez "
"utiliser la forme suivante : {name}: type = property_field(...)"

#: hetu/data/component.py:491
#, python-brace-format
msgid "{cls_name}至少要有1个Property成员"
msgstr "{cls_name} doit avoir au moins 1 membre Property."

#: hetu/data/component.py:497
#, python-brace-format
msgid "{cls_name}.id是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}.id est une clé primaire intégrée réservée et ne peut pas être "
"redéfinie en externe."

#: hetu/data/component.py:500
#, python-brace-format
msgid "{cls_name}._version是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}._version est une clé primaire intégrée réservée et ne peut pas"
" être redéfinie en externe."

#: hetu/data/component.py:509
#, python-brace-format
msgid "{cls_name}必须继承于BaseComponent"
msgstr "{cls_name} doit hériter de BaseComponent."

#: hetu/data/migration.py:39
#, python-brace-format
msgid "  ➖ [💾Redis][{comp_name}组件] 发现自定义迁移脚本 {file}，将调用脚本进行迁移..."
msgstr ""
"  ➖ [💾Redis][Composant {comp_name}] Script de migration personnalisé "
"{file} détecté, appel du script pour migration..."

#: hetu/data/migration.py:88
#, python-brace-format
msgid ""
"  ➖ [💾Redis][{comp_name}组件] 缺少迁移脚本，生成默认迁移脚本 "
"{script_path}，请根据需要修改脚本内容后再执行迁移操作..."
msgstr ""
"  ➖ [💾Redis][Composant {comp_name}] Script de migration manquant, "
"génération du script de migration par défaut {script_path}, veuillez "
"modifier le contenu du script selon vos besoins avant d'exécuter la "
"migration..."

#: hetu/data/migration.py:200
#, python-brace-format
msgid "  ➖ [💾Redis][{comp_name}组件] 执行upgrade迁移：{module}"
msgstr ""
"  ➖ [💾Redis][Composant {comp_name}] Exécution de la migration upgrade : "
"{module}"

#: hetu/data/migration.py:207
#, python-brace-format
msgid "  ✔️ [💾Redis][{comp_name}组件] Schema升级迁移完成，共处理{count}行"
msgstr ""
"  ✔️ [💾Redis][Composant {comp_name}] Migration de mise à niveau du schéma"
" terminée, {count} lignes traitées"

#: hetu/data/migration.py:212
#, python-brace-format
msgid "  ✔️ [💾Redis][{comp_name}组件] 已重建Index"
msgstr "  ✔️ [💾Redis][Composant {comp_name}] Index reconstruit"

#: hetu/data/sub.py:179
#, python-brace-format
msgid "IndexSubscription收到了未知的channel消息: {channel}"
msgstr "IndexSubscription a reçu un message de canal inconnu : {channel}"

#: hetu/data/sub.py:294 hetu/data/sub.py:385
#, python-brace-format
msgid "⚠️ [📡Subscription] {sub_id} 数据重复订阅，检查客户端代码"
msgstr ""
"⚠️ [📡Subscription] {sub_id} double abonnement aux données, vérifiez le "
"code client"

#: hetu/data/sub.py:303
#, python-brace-format
msgid "🆕 [📡Subscription] 订阅了行: {sub_id} {channel_name}"
msgstr "🆕 [📡Subscription] ligne souscrite : {sub_id} {channel_name}"

#: hetu/data/sub.py:359
#, python-brace-format
msgid "⚠️ [📡Subscription] {comp_name}无调用权限，检查是否非法调用，caller：{caller}"
msgstr ""
"⚠️ [📡Subscription] {comp_name} n'a pas les droits d'appel, vérifiez si "
"l'appel est illégal, appelant : {caller}"

#: hetu/data/sub.py:394
#, python-brace-format
