#: hetu/cli/migrate.py:34
msgid "在数据库执行Schema升级脚本,如果没有则创建，如果无变更则跳过。同时还会进行临时表的清空。应该在CI/CD流程中，每次启动服务器前执行一次。"
msgstr ""
"تنفيذ سكربت ترقية مخطط قاعدة البيانات، وإنشاؤه إذا لم يكن موجودًا، وتخطيه"
" إذا لم يكن هناك تغيير. كما سيتم إفراغ الجداول المؤقتة. يجب تنفيذ هذا مرة"
" واحدة قبل تشغيل الخادم في كل عملية CI/CD."

#: hetu/cli/migrate.py:41 hetu/cli/start.py:100
msgid "后端数据库地址"
msgstr "عنق قاعدة البيانات الخلفية"

#: hetu/cli/migrate.py:51 hetu/cli/start.py:89
msgid "启动app.py中哪个namespace下的System"
msgstr "أي System ضمن namespace في app.py لتشغيله"

#: hetu/cli/migrate.py:54 hetu/cli/start.py:92
msgid "实例名称，每个实例是一个副本"
msgstr "اسم المثيل، كل مثيل هو نسخة مكررة"

#: hetu/cli/migrate.py:58
msgid "通过yml配置文件读取后端数据库地址"
msgstr "قراءة عنوان قاعدة البيانات الخلفية من ملف تكوين yml"

#: hetu/cli/migrate.py:64
msgid "自动确认数据备份提示"
msgstr "تأكيد تلقائي لرسالة نسخ البيانات الاحتياطية"

#: hetu/cli/migrate.py:70
msgid "强制执行升级迁移，丢弃无法迁移的数据。请勿在生产环境使用此选项！"
msgstr ""
"فرض ترقية الهجرة، مع تجاهل البيانات التي لا يمكن نقلها. لا تستخدم هذا "
"الخيار في بيئة الإنتاج!"

#: hetu/cli/migrate.py:104
msgid "⚠️  升级数据库表结构可能会导致数据丢失，请确保已备份数据。确认继续请输 y ，取消请输其他键然后回车："
msgstr ""
"⚠️   قد يؤدي ترقية هيكل جداول قاعدة البيانات إلى فقدان البيانات، يرجى "
"التأكد من نسخ البيانات احتياطيًا. للتأكيد والمتابعة أدخل y ، للإلغاء أدخل"
" أي مفتاح آخر ثم اضغط Enter:"

#: hetu/cli/migrate.py:109 hetu/cli/migrate.py:136
msgid "❌  升级迁移已取消。"
msgstr "❌   تم إلغاء ترقية الهجرة."

#: hetu/cli/migrate.py:126
msgid "❗ Component有数据删除或类型变更，请修改自动生成的迁移脚本，手动处理这些属性。或使用--drop-data参数直接丢弃这些属性。"
msgstr ""
"❗ هناك حذف بيانات أو تغيير نوع في Component، يرجى تعديل سكربت الهجرة "
"المُنشأ تلقائيًا ومعالجة هذه الخصائص يدويًا. أو استخدم المعامل --drop-"
"data لتجاهل هذه الخصائص مباشرة."

#: hetu/cli/migrate.py:133
msgid "⚠️  确认强制迁移请输 y ，取消请输其他键然后回车："
msgstr "⚠️   لتأكيد فرض الهجرة أدخل y ، للإلغاء أدخل أي مفتاح آخر ثم اضغط Enter:"

#: hetu/cli/migrate.py:139
#, python-brace-format
msgid "⚠️  正在强制迁移 {instance_name} 服所有表结构，可能会丢失数据..."
msgstr ""
"⚠️   جاري فرض هجرة جميع هياكل الجداول لخادم {instance_name}، قد يؤدي ذلك "
"إلى فقدان البيانات..."

#: hetu/cli/migrate.py:147
#, python-brace-format
msgid "🧹 正在清除 {instance_name} 服易失数据..."
msgstr "🧹 جاري تنظيف البيانات المتطايرة لخادم {instance_name}..."

#: hetu/cli/migrate.py:150
#, python-brace-format
msgid "✅  {instance_name} 服升级迁移完成！"
msgstr "✅  اكتملت ترقية وهجرة خادم {instance_name}!"

#: hetu/cli/migrate.py:151
msgid "🎉  恭喜！所有数据库表结构均已升级完成！"
msgstr "🎉  مبروك! تمت ترقية جميع هياكل جداول قاعدة البيانات بنجاح!"

#: hetu/cli/migrate.py:173
msgid "namespace参数不能为空，建议用--config参数"
msgstr "معامل namespace لا يمكن أن يكون فارغًا، يُنصح باستخدام المعامل --config"

#: hetu/cli/migrate.py:174
msgid "instance参数不能为空，建议用--config参数"
msgstr "معامل instance لا يمكن أن يكون فارغًا، يُنصح باستخدام المعامل --config"

#: hetu/cli/migrate.py:175
msgid "app_file参数不能为空，建议用--config参数"
msgstr "معامل app_file لا يمكن أن يكون فارغًا، يُنصح باستخدام المعامل --config"

#: hetu/cli/start.py:52
#, python-brace-format
msgid ""
"不支持的数据库URL scheme: '{scheme}'。目前支持 "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"
msgstr ""
"مخطط URL لقاعدة البيانات غير مدعوم: '{scheme}'. المدعوم حاليًا: "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"

#: hetu/cli/start.py:77
msgid "启动河图服务"
msgstr "تشغيل خدمة Hetu"

#: hetu/cli/start.py:79
msgid "通过命令行启动参数"
msgstr "عبر معلمات سطر الأوامر"

#: hetu/cli/start.py:95
msgid "监听的Websocket端口"
msgstr "منفذ Websocket للاستماع"

#: hetu/cli/start.py:104
msgid "工作进程数，可设为 CPU * 1.2"
msgstr "عدد عمليات العمل، يمكن ضبطه على CPU * 1.2"

#: hetu/cli/start.py:112
msgid "开启debug模式，这会启动代码热更新，并显示更多的log信息。如果设置为2，则对框架内核也启用debug模式，会开启Python协程的Debug模式，速度慢90％。"
msgstr ""
"تفعيل وضع التصحيح، سيؤدي هذا إلى تشغيل التحديث الساخن للكود وعرض المزيد "
"من معلومات السجل. إذا تم ضبطه على 2، فسيتم تفعيل وضع التصحيح لنواة الإطار"
" أيضًا، مما يؤدي إلى تفعيل وضع تصحيح Python للمهام المتعاونة، مما يبطئ "
"السرعة بنسبة 90٪."

#: hetu/cli/start.py:122
msgid "证书目录，如果不设置则使用不安全的连接。不建议这里设置，请外加一层反向https代理。填入auto会生成自签https证书。"
msgstr ""
"دليل الشهادات، إذا لم يتم تعيينه فسيتم استخدام اتصال غير آمن. لا ينصح "
"بالتعيين هنا، يرجى إضافة طبقة وكيل عكسي https خارجية. سيؤدي إدخال 'auto' "
"إلى إنشاء شهادة https ذاتية التوقيع."

#: hetu/cli/start.py:130
msgid "默认crypto层的auth_key，用于握手签名校验。留空则不启用。"
msgstr ""
"مفتاح المصادقة الافتراضي لطبقة التشفير، يستخدم للتحقق من توقيع المصافحة. "
"اتركه فارغًا لتعطيله."

#: hetu/cli/start.py:137
msgid "配置文件模板见CONFIG_TEMPLATE.yml"
msgstr "نموذج ملف الإعدادات في CONFIG_TEMPLATE.yml"

#: hetu/cli/start.py:155
msgid "--app_file是必须参数，或者用--config"
msgstr "--app_file معلمة إلزامية، أو استخدم --config"

#: hetu/cli/start.py:158
msgid "--namespace是必须参数，或者用--config"
msgstr "--namespace معلمة إلزامية، أو استخدم --config"

#: hetu/cli/start.py:161
msgid "--instance是必须参数，或者用--config"
msgstr "--instance معلمة إلزامية، أو استخدم --config"

#: hetu/cli/start.py:218
#, python-brace-format
msgid "ℹ️ {name}, {mode}, {workers} 个工作进程, 管理进程 pid: {pid}"
msgstr "ℹ️ {name}, {mode}, {workers} عمليات عمل, معرف عملية الإدارة: {pid}"

#: hetu/cli/start.py:226
#, python-brace-format
msgid "ℹ️ Python {version} 平台 {platform}"
msgstr "ℹ️ Python {version} منصة {platform}"

#: hetu/cli/start.py:231
#, python-brace-format
msgid "📡 监听地址： http{s}://{host}:{port}"
msgstr "📡 عنوان الاستماع: http{s}://{host}:{port}"

#: hetu/cli/start.py:237
#, python-brace-format
msgid "ℹ️ 消息流协议：json -> {layers} -> Network"
msgstr "ℹ️ بروتوكول تدفق الرسائل: json -> {layers} -> الشبكة"

#: hetu/cli/start.py:244
msgid "⚠️⚠️⚠️ 深度Debug模式开启  ⚠️⚠️⚠️   此模式下Python协程慢90%"
msgstr ""
"⚠️⚠️⚠️ تم تفعيل وضع التصحيح العميق ⚠️⚠️⚠️   المهام المتعاونة لـ Python "
"أبطأ بنسبة 90٪ في هذا الوضع"

#: hetu/common/slowlog.py:72
#, python-brace-format
msgid ""
"⚠️ [📞慢日志] 系统 {name} 执行时间 {elapsed}秒，事务冲突次数 {retry}，平均时间 {avg_time}秒\n"
"{table}"
msgstr ""
"⚠️ [📞 سجل بطيء] النظام {name} وقت التنفيذ {elapsed} ثانية، عدد تعارضات "
"المعاملات {retry}، متوسط الوقت {avg_time} ثانية\n"
"{table}"

#: hetu/common/slowlog.py:99
msgid "系统"
msgstr "النظام"

#: hetu/common/slowlog.py:99
msgid "平均时间"
msgstr "متوسط الوقت"

#: hetu/common/slowlog.py:99
msgid "平均冲突次数"
msgstr "متوسط عدد التعارضات"

#: hetu/common/snowflake_id.py:84
#, python-brace-format
msgid "Worker ID不能大于{max}或小于0"
msgstr "معرف العامل لا يمكن أن يكون أكبر من {max} أو أقل من 0"

#: hetu/common/snowflake_id.py:98
#, python-brace-format
msgid "[❄️ID] 雪花ID生成器初始化完成，Worker ID: {worker_id}, last_timestamp: {ts}"
msgstr ""
"[❄️ID] تم تهيئة مولد معرفات Snowflake، معرف العامل: {worker_id}, "
"last_timestamp: {ts}"

#: hetu/common/snowflake_id.py:110
msgid "SnowflakeID 未初始化，请先调用 init() 方法。"
msgstr "SnowflakeID غير مهيأ، يرجى استدعاء طريقة init() أولاً."

#: hetu/common/snowflake_id.py:119
#, python-brace-format
msgid "[❄️ID] 时钟回拨了 {ms} 毫秒。"
msgstr "[❄️ID] تمت إعادة ضبط الساعة بمقدار {ms} مللي ثانية."

#: hetu/common/snowflake_id.py:154 hetu/common/snowflake_id.py:170
msgid "[❄️ID] 每毫秒只能生成有限的ID，需要休眠 1 ms"
msgstr ""
"[❄️ID] يمكن إنشاء عدد محدود من المعرفات في كل مللي ثانية، يجب الانتظار "
"لمدة 1 مللي ثانية"

#: hetu/data/component.py:253
msgid "Component重复定义"
msgstr "تكرار تعريف المكون (Component)"

#: hetu/data/component.py:369
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是Python关键字。"
msgstr ""
"خطأ في تعريف خاصية {cname}.{fname}، لا يمكن أن يكون اسم الخاصية كلمة "
"مفتاحية في Python."

#: hetu/data/component.py:375
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是C#关键字。"
msgstr ""
"خطأ في تعريف خاصية {cname}.{fname}، لا يمكن أن يكون اسم الخاصية كلمة "
"مفتاحية في C#."

#: hetu/data/component.py:381
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不能为0长度。str类型请用'<U8'方式定义"
msgstr ""
"لا يمكن أن يكون dtype الخاصية {cname}.{fname} بطول صفر. بالنسبة لنوع str،"
" يُرجى تعريفه باستخدام '<U8'."

#: hetu/data/component.py:384
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不支持void类型"
msgstr "نوع void غير مدعوم لـ dtype الخاصية {cname}.{fname}."

#: hetu/data/component.py:394
#, python-brace-format
msgid "⚠️ [🛠️Define] {cname}.{fname}属性设置为unique时，index不能设置为False。"
msgstr ""
"⚠️ [🛠️Define] عند تعيين الخاصية {cname}.{fname} كـ unique، لا يمكن تعيين "
"index إلى False."

#: hetu/data/component.py:401
#, python-brace-format
msgid ""
"{cname}.{fname}默认值不能为None。所有属性都要有默认值，因为数据接口统一用c like "
"struct实现，强类型struct不接受NULL/None值。"
msgstr ""
"لا يمكن أن تكون القيمة الافتراضية للخاصية {cname}.{fname} هي None. يجب أن"
" يكون لكل خاصية قيمة افتراضية، لأن واجهات البيانات تُنفذ بشكل موحد "
"باستخدام struct شبيه بـ C، ولا تقبل struct ذات النوع القوي قيم NULL/None."

#: hetu/data/component.py:412
#, python-brace-format
msgid "{cname}.{fname}的default值：{default_type}({default_value})和属性dtype({dtype})不匹配"
msgstr ""
"قيمة default للخاصية {cname}.{fname}: {default_type}({default_value}) لا "
"تتطابق مع dtype الخاصية ({dtype})."

#: hetu/data/component.py:426
#, python-brace-format
msgid "{cname}权限为OWNER时，不能设置rls_compare参数"
msgstr "عندما تكون صلاحية {cname} هي OWNER، لا يمكن تعيين معلمة rls_compare."

#: hetu/data/component.py:429
#, python-brace-format
msgid "{cname}权限为OWNER时，必须有owner属性"
msgstr "عندما تكون صلاحية {cname} هي OWNER، يجب أن تحتوي على خاصية owner."

#: hetu/data/component.py:436
#, python-brace-format
msgid "{cname}的owner属性必需是numeric数字(int, np.int64, ...)类型"
msgstr "يجب أن تكون خاصية owner لـ {cname} من النوع الرقمي (int, np.int64, ...)."

#: hetu/data/component.py:442
#, python-brace-format
msgid "{cname}权限为RLS时，必须通过rls_compare参数定义行级权限逻辑"
msgstr ""
"عندما تكون صلاحية {cname} هي RLS، يجب تعريف منطق صلاحية مستوى الصف من "
"خلال معلمة rls_compare."

#: hetu/data/component.py:445
#, python-brace-format
msgid "{cname}.rls_compare参数必须全部是字符串类型"
msgstr ""
"يجب أن تكون جميع معلمات {cname}.rls_compare من نوع السلسلة النصية "
"(string)."

#: hetu/data/component.py:448
#, python-brace-format
msgid "{cname}.rls_compare参数必须只有3个元素)"
msgstr "يجب أن تحتوي معلمة {cname}.rls_compare على 3 عناصر فقط."

#: hetu/data/component.py:452
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但operator模块没有{method}方法"
msgstr ""
"الصلاحية لـ {cname} هي RLS: {rls_compare}، لكن وحدة operator لا تحتوي على"
" طريقة {method}."

#: hetu/data/component.py:456
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但表没有定义{prop}属性"
msgstr ""
"الصلاحية لـ {cname} هي RLS: {rls_compare}، لكن الجدول لم يُعرّف الخاصية "
"{prop}."

#: hetu/data/component.py:463
#, python-brace-format
msgid "组件名({name})是C#关键字，请refactor。"
msgstr "اسم المكون ({name}) هو كلمة مفتاحية في C#، يُرجى إعادة الهيكلة (refactor)."

#: hetu/data/component.py:476
#, python-brace-format
msgid "{cls_name}.{name}不是Property类型"
msgstr "{cls_name}.{name} ليس من نوع Property."

#: hetu/data/component.py:486
#, python-brace-format
msgid "{cls_name}.{name}属性未定义type hint。请使用以下形式，{name}: type = property_field(...)"
msgstr ""
"الخاصية {cls_name}.{name} لم تُعرّف type hint. يُرجى استخدام الصيغة "
"التالية: {name}: type = property_field(...)"

#: hetu/data/component.py:491
#, python-brace-format
msgid "{cls_name}至少要有1个Property成员"
msgstr "يجب أن يحتوي {cls_name} على عضو Property واحد على الأقل."

#: hetu/data/component.py:497
#, python-brace-format
msgid "{cls_name}.id是保留的内置主键，外部不能重定义"
msgstr "{cls_name}.id هو مفتاح أساسي مدمج محجوز، ولا يمكن إعادة تعريفه من الخارج."

#: hetu/data/component.py:500
#, python-brace-format
msgid "{cls_name}._version是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}._version هو مفتاح أساسي مدمج محجوز، ولا يمكن إعادة تعريفه من "
"الخارج."

#: hetu/data/component.py:509
#, python-brace-format
msgid "{cls_name}必须继承于BaseComponent"
msgstr "يجب أن يرث {cls_name} من BaseComponent."

