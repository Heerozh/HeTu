#: hetu/manager.py:56
#, python-brace-format
msgid "Backend {backend}未找到"
msgstr "Бэкенд {backend} не найден"

#: hetu/manager.py:100
#, python-brace-format
msgid "⚠️  组件 {comp_name} 的表结构需要迁移Schema。"
msgstr "⚠️  Для компонента {comp_name} требуется миграция схемы таблицы."

#: hetu/manager.py:107
#, python-brace-format
msgid "⚠️  组件 {comp_name} 的表需要迁移到新集群。"
msgstr "⚠️  Таблицу компонента {comp_name} необходимо перенести в новый кластер."

#: hetu/cli/__init__.py:25
msgid "河图数据库"
msgstr "База данных Hetu"

#: hetu/cli/__init__.py:29
msgid "执行操作"
msgstr "Выполнить операцию"

#: hetu/cli/base.py:21
msgid "Boolean value expected."
msgstr "Ожидается логическое значение."

#: hetu/cli/build.py:22
msgid "生成客户端SDK C# 类型代码"
msgstr "Сгенерировать код типов C# для клиентского SDK"

#: hetu/cli/build.py:26 hetu/cli/migrate.py:46 hetu/cli/start.py:82
msgid "河图app的py文件"
msgstr "Python-файл приложения Hetu"

#: hetu/cli/build.py:33
msgid "编译app.py中哪个namespace下的数据类型"
msgstr "Какие типы данных в namespace компилировать из app.py"

#: hetu/cli/build.py:37
msgid "输出文件路径"
msgstr "Путь к выходному файлу"

#: hetu/cli/build.py:46 hetu/cli/migrate.py:92
#, python-brace-format
msgid "无法加载app文件 {app_file}"
msgstr "Не удалось загрузить файл приложения {app_file}"

#: hetu/cli/build.py:59
#, python-brace-format
msgid "✅ 已生成C#代码到 {output}"
msgstr "✅ Код C# сгенерирован в {output}"

#: hetu/cli/migrate.py:34
msgid "在数据库执行Schema升级脚本,如果没有则创建，如果无变更则跳过。同时还会进行临时表的清空。应该在CI/CD流程中，每次启动服务器前执行一次。"
msgstr ""
"Выполняет скрипт обновления схемы в базе данных. Если скрипта нет — "
"создаёт, если изменений нет — пропускает. Также очищает временные "
"таблицы. Должен выполняться один раз перед каждым запуском сервера в "
"процессе CI/CD."

#: hetu/cli/migrate.py:41 hetu/cli/start.py:100
msgid "后端数据库地址"
msgstr "Адрес серверной базы данных"

#: hetu/cli/migrate.py:51 hetu/cli/start.py:89
msgid "启动app.py中哪个namespace下的System"
msgstr "Какую System в namespace запустить из app.py"

#: hetu/cli/migrate.py:54 hetu/cli/start.py:92
msgid "实例名称，每个实例是一个副本"
msgstr "Имя экземпляра, каждый экземпляр — это реплика"

#: hetu/cli/migrate.py:58
msgid "通过yml配置文件读取后端数据库地址"
msgstr "Читает адрес серверной базы данных из конфигурационного файла yml"

#: hetu/cli/migrate.py:64
msgid "自动确认数据备份提示"
msgstr "Автоматически подтверждает запрос о резервном копировании данных"

#: hetu/cli/migrate.py:70
msgid "强制执行升级迁移，丢弃无法迁移的数据。请勿在生产环境使用此选项！"
msgstr ""
"Принудительно выполнить миграцию, удалив данные, которые невозможно "
"перенести. Не используйте эту опцию в рабочей среде!"

#: hetu/cli/migrate.py:104
msgid "⚠️  升级数据库表结构可能会导致数据丢失，请确保已备份数据。确认继续请输 y ，取消请输其他键然后回车："
msgstr ""
"⚠️  Обновление структуры таблиц базы данных может привести к потере "
"данных. Убедитесь, что данные сохранены. Для подтверждения введите y, для"
" отмены — любую другую клавишу и нажмите Enter:"

#: hetu/cli/migrate.py:109 hetu/cli/migrate.py:136
msgid "❌  升级迁移已取消。"
msgstr "❌  Миграция обновления отменена."

#: hetu/cli/migrate.py:126
msgid "❗ Component有数据删除或类型变更，请修改自动生成的迁移脚本，手动处理这些属性。或使用--drop-data参数直接丢弃这些属性。"
msgstr ""
"❗ В Component произошло удаление данных или изменение типа. Измените "
"автоматически сгенерированный скрипт миграции, чтобы обработать эти "
"свойства вручную. Или используйте параметр --drop-data для их прямого "
"удаления."

#: hetu/cli/migrate.py:133
msgid "⚠️  确认强制迁移请输 y ，取消请输其他键然后回车："
msgstr ""
"⚠️  Для подтверждения принудительной миграции введите y, для отмены — "
"любую другую клавишу и нажмите Enter:"

#: hetu/cli/migrate.py:139
#, python-brace-format
msgid "⚠️  正在强制迁移 {instance_name} 服所有表结构，可能会丢失数据..."
msgstr ""
"⚠️  Выполняется принудительная миграция структуры всех таблиц для сервера"
" {instance_name}, возможна потеря данных..."

#: hetu/cli/migrate.py:147
#, python-brace-format
msgid "🧹 正在清除 {instance_name} 服易失数据..."
msgstr "🧹 Очищаю временные данные для сервера {instance_name}..."

#: hetu/cli/migrate.py:150
#, python-brace-format
msgid "✅  {instance_name} 服升级迁移完成！"
msgstr "✅  Миграция обновления для сервера {instance_name} завершена!"

#: hetu/cli/migrate.py:151
msgid "🎉  恭喜！所有数据库表结构均已升级完成！"
msgstr "🎉  Поздравляем! Структура всех таблиц базы данных успешно обновлена!"

#: hetu/cli/migrate.py:173
msgid "namespace参数不能为空，建议用--config参数"
msgstr ""
"Параметр namespace не может быть пустым, рекомендуется использовать "
"параметр --config"

#: hetu/cli/migrate.py:174
msgid "instance参数不能为空，建议用--config参数"
msgstr ""
"Параметр instance не может быть пустым, рекомендуется использовать "
"параметр --config"

#: hetu/cli/migrate.py:175
msgid "app_file参数不能为空，建议用--config参数"
msgstr ""
"Параметр app_file не может быть пустым, рекомендуется использовать "
"параметр --config"

#: hetu/cli/start.py:52
#, python-brace-format
msgid ""
"不支持的数据库URL scheme: '{scheme}'。目前支持 "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"
msgstr ""
"Неподдерживаемая схема URL базы данных: '{scheme}'. В настоящее время "
"поддерживаются "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"

#: hetu/cli/start.py:77
msgid "启动河图服务"
msgstr "Запуск службы Hetu"

#: hetu/cli/start.py:79
msgid "通过命令行启动参数"
msgstr "Параметры запуска через командную строку"

#: hetu/cli/start.py:95
msgid "监听的Websocket端口"
msgstr "Порт Websocket для прослушивания"

#: hetu/cli/start.py:104
msgid "工作进程数，可设为 CPU * 1.2"
msgstr "Количество рабочих процессов, можно установить как CPU * 1.2"

#: hetu/cli/start.py:112
msgid "开启debug模式，这会启动代码热更新，并显示更多的log信息。如果设置为2，则对框架内核也启用debug模式，会开启Python协程的Debug模式，速度慢90％。"
msgstr ""
"Включить режим отладки (debug). Это запустит горячее обновление кода и "
"покажет больше информации в логах. Если установить значение 2, то режим "
"отладки будет включён и для ядра фреймворка, что активирует режим отладки"
" Python-корутин и замедлит работу на 90%."

#: hetu/cli/start.py:122
msgid "证书目录，如果不设置则使用不安全的连接。不建议这里设置，请外加一层反向https代理。填入auto会生成自签https证书。"
msgstr ""
"Каталог сертификатов. Если не установлен, используется небезопасное "
"соединение. Не рекомендуется устанавливать здесь, лучше добавить внешний "
"обратный HTTPS-прокси. Ввод 'auto' сгенерирует самоподписанный "
"HTTPS-сертификат."

#: hetu/cli/start.py:130
msgid "默认crypto层的auth_key，用于握手签名校验。留空则不启用。"
msgstr ""
"Ключ аутентификации (auth_key) по умолчанию для криптографического слоя, "
"используется для проверки подписи при рукопожатии. Оставьте пустым для "
"отключения."

#: hetu/cli/start.py:137
msgid "配置文件模板见CONFIG_TEMPLATE.yml"
msgstr "Шаблон конфигурационного файла см. в CONFIG_TEMPLATE.yml"

#: hetu/cli/start.py:155
msgid "--app_file是必须参数，或者用--config"
msgstr "--app_file является обязательным параметром, либо используйте --config"

#: hetu/cli/start.py:158
msgid "--namespace是必须参数，或者用--config"
msgstr "--namespace является обязательным параметром, либо используйте --config"

#: hetu/cli/start.py:161
msgid "--instance是必须参数，或者用--config"
msgstr "--instance является обязательным параметром, либо используйте --config"

#: hetu/cli/start.py:218
#, python-brace-format
msgid "ℹ️ {name}, {mode}, {workers} 个工作进程, 管理进程 pid: {pid}"
msgstr ""
"ℹ️ {name}, {mode}, {workers} рабочих процессов, pid управляющего "
"процесса: {pid}"

#: hetu/cli/start.py:226
#, python-brace-format
msgid "ℹ️ Python {version} 平台 {platform}"
msgstr "ℹ️ Python {version}, платформа {platform}"

#: hetu/cli/start.py:231
#, python-brace-format
msgid "📡 监听地址： http{s}://{host}:{port}"
msgstr "📡 Адрес прослушивания: http{s}://{host}:{port}"

#: hetu/cli/start.py:237
#, python-brace-format
msgid "ℹ️ 消息流协议：json -> {layers} -> Network"
msgstr "ℹ️ Протокол потока сообщений: json -> {layers} -> Network"

#: hetu/cli/start.py:244
msgid "⚠️⚠️⚠️ 深度Debug模式开启  ⚠️⚠️⚠️   此模式下Python协程慢90%"
msgstr ""
"⚠️⚠️⚠️ Включён режим глубокой отладки ⚠️⚠️⚠️   В этом режиме "
"Python-корутины работают на 90% медленнее"

#: hetu/common/slowlog.py:72
#, python-brace-format
msgid ""
"⚠️ [📞慢日志] 系统 {name} 执行时间 {elapsed}秒，事务冲突次数 {retry}，平均时间 {avg_time}秒\n"
"{table}"
msgstr ""
"⚠️ [📞 Медленный журнал] Система {name} время выполнения {elapsed} сек., "
"количество конфликтов транзакций {retry}, среднее время {avg_time} сек.\n"
"{table}"

#: hetu/common/slowlog.py:99
msgid "系统"
msgstr "Система"

#: hetu/common/slowlog.py:99
msgid "平均时间"
msgstr "Среднее время"

#: hetu/common/slowlog.py:99
msgid "平均冲突次数"
msgstr "Среднее количество конфликтов"

#: hetu/common/snowflake_id.py:84
#, python-brace-format
msgid "Worker ID不能大于{max}或小于0"
msgstr "Worker ID не может быть больше {max} или меньше 0"

#: hetu/common/snowflake_id.py:98
#, python-brace-format
msgid "[❄️ID] 雪花ID生成器初始化完成，Worker ID: {worker_id}, last_timestamp: {ts}"
msgstr ""
"[❄️ID] Генератор снежинчатых ID инициализирован, Worker ID: {worker_id}, "
"last_timestamp: {ts}"

#: hetu/common/snowflake_id.py:110
msgid "SnowflakeID 未初始化，请先调用 init() 方法。"
msgstr "SnowflakeID не инициализирован, сначала вызовите метод init()."

#: hetu/common/snowflake_id.py:119
#, python-brace-format
msgid "[❄️ID] 时钟回拨了 {ms} 毫秒。"
msgstr "[❄️ID] Часы отстали на {ms} миллисекунд."

#: hetu/common/snowflake_id.py:154 hetu/common/snowflake_id.py:170
msgid "[❄️ID] 每毫秒只能生成有限的ID，需要休眠 1 ms"
msgstr ""
"[❄️ID] В каждой миллисекунде можно сгенерировать ограниченное количество "
"ID, требуется ожидание 1 мс"

#: hetu/data/component.py:253
msgid "Component重复定义"
msgstr "Повторное определение компонента"

#: hetu/data/component.py:369
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是Python关键字。"
msgstr ""
"Ошибка определения атрибута {cname}.{fname}: имя атрибута не может быть "
"ключевым словом Python."

#: hetu/data/component.py:375
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是C#关键字。"
msgstr ""
"Ошибка определения атрибута {cname}.{fname}: имя атрибута не может быть "
"ключевым словом C#."

#: hetu/data/component.py:381
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不能为0长度。str类型请用'<U8'方式定义"
msgstr ""
"dtype атрибута {cname}.{fname} не может быть нулевой длины. Для "
"строкового типа используйте определение вида '<U8'."

#: hetu/data/component.py:384
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不支持void类型"
msgstr "dtype атрибута {cname}.{fname} не поддерживает тип void."

#: hetu/data/component.py:394
#, python-brace-format
msgid "⚠️ [🛠️Define] {cname}.{fname}属性设置为unique时，index不能设置为False。"
msgstr ""
"⚠️ [🛠️Define] При установке атрибута {cname}.{fname} как unique, index не"
" может быть установлен в False."

#: hetu/data/component.py:401
#, python-brace-format
msgid ""
"{cname}.{fname}默认值不能为None。所有属性都要有默认值，因为数据接口统一用c like "
"struct实现，强类型struct不接受NULL/None值。"
msgstr ""
"Значение по умолчанию для {cname}.{fname} не может быть None. Все "
"атрибуты должны иметь значение по умолчанию, поскольку интерфейс данных "
"реализован как структура в стиле C, а строго типизированные структуры не "
"принимают значения NULL/None."

#: hetu/data/component.py:412
#, python-brace-format
msgid "{cname}.{fname}的default值：{default_type}({default_value})和属性dtype({dtype})不匹配"
msgstr ""
"Значение по умолчанию для {cname}.{fname}: "
"{default_type}({default_value}) не соответствует dtype атрибута "
"({dtype})."

#: hetu/data/component.py:426
#, python-brace-format
msgid "{cname}权限为OWNER时，不能设置rls_compare参数"
msgstr ""
"Для компонента {cname} с правами OWNER нельзя устанавливать параметр "
"rls_compare."

#: hetu/data/component.py:429
#, python-brace-format
msgid "{cname}权限为OWNER时，必须有owner属性"
msgstr ""
"Для компонента {cname} с правами OWNER должен быть определен атрибут "
"owner."

#: hetu/data/component.py:436
#, python-brace-format
msgid "{cname}的owner属性必需是numeric数字(int, np.int64, ...)类型"
msgstr ""
"Атрибут owner компонента {cname} должен быть числового типа (int, "
"np.int64, ...)."

#: hetu/data/component.py:442
#, python-brace-format
msgid "{cname}权限为RLS时，必须通过rls_compare参数定义行级权限逻辑"
msgstr ""
"Для компонента {cname} с правами RLS необходимо определить логику "
"контроля на уровне строк через параметр rls_compare."

#: hetu/data/component.py:445
#, python-brace-format
msgid "{cname}.rls_compare参数必须全部是字符串类型"
msgstr "Все параметры rls_compare компонента {cname} должны быть строкового типа."

#: hetu/data/component.py:448
#, python-brace-format
msgid "{cname}.rls_compare参数必须只有3个元素)"
msgstr "Параметр rls_compare компонента {cname} должен содержать ровно 3 элемента."

#: hetu/data/component.py:452
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但operator模块没有{method}方法"
msgstr ""
"Для компонента {cname} с правами RLS: {rls_compare}, но в модуле operator"
" отсутствует метод {method}."

#: hetu/data/component.py:456
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但表没有定义{prop}属性"
msgstr ""
"Для компонента {cname} с правами RLS: {rls_compare}, но в таблице не "
"определен атрибут {prop}."

#: hetu/data/component.py:463
#, python-brace-format
msgid "组件名({name})是C#关键字，请refactor。"
msgstr ""
"Имя компонента ({name}) является ключевым словом C#. Пожалуйста, "
"выполните рефакторинг."

#: hetu/data/component.py:476
#, python-brace-format
msgid "{cls_name}.{name}不是Property类型"
msgstr "{cls_name}.{name} не является типом Property."

#: hetu/data/component.py:486
#, python-brace-format
msgid "{cls_name}.{name}属性未定义type hint。请使用以下形式，{name}: type = property_field(...)"
msgstr ""
"Для атрибута {cls_name}.{name} не определен type hint. Используйте "
"следующий формат: {name}: type = property_field(...)"

#: hetu/data/component.py:491
#, python-brace-format
msgid "{cls_name}至少要有1个Property成员"
msgstr "Класс {cls_name} должен иметь как минимум 1 член типа Property."

#: hetu/data/component.py:497
#, python-brace-format
msgid "{cls_name}.id是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}.id — это встроенный зарезервированный первичный ключ, его "
"нельзя переопределять извне."

#: hetu/data/component.py:500
#, python-brace-format
msgid "{cls_name}._version是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}._version — это встроенный зарезервированный первичный ключ, "
"его нельзя переопределять извне."

#: hetu/data/component.py:509
#, python-brace-format
msgid "{cls_name}必须继承于BaseComponent"
msgstr "{cls_name} должен наследоваться от BaseComponent."

#: hetu/data/migration.py:39
#, python-brace-format
msgid "  ➖ [💾Redis][{comp_name}组件] 发现自定义迁移脚本 {file}，将调用脚本进行迁移..."
msgstr ""
"  ➖ [💾Redis][компонент {comp_name}] Обнаружен пользовательский скрипт "
"миграции {file}, будет вызван для выполнения миграции..."

#: hetu/data/migration.py:88
#, python-brace-format
msgid ""
"  ➖ [💾Redis][{comp_name}组件] 缺少迁移脚本，生成默认迁移脚本 "
"{script_path}，请根据需要修改脚本内容后再执行迁移操作..."
msgstr ""
