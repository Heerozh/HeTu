#: hetu/cli/start.py:52
#, python-brace-format
msgid ""
"不支持的数据库URL scheme: '{scheme}'。目前支持 "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"
msgstr ""
"Unsupported database URL scheme: '{scheme}'. Currently supported: "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"

#: hetu/cli/start.py:77
msgid "启动河图服务"
msgstr "Start Hetu service"

#: hetu/cli/start.py:79
msgid "通过命令行启动参数"
msgstr "Via command line startup parameters"

#: hetu/cli/start.py:82
msgid "河图app的py文件"
msgstr "Python file for the Hetu app"

#: hetu/cli/start.py:89
msgid "启动app.py中哪个namespace下的System"
msgstr "Which System under which namespace in app.py to start"

#: hetu/cli/start.py:92
msgid "实例名称，每个实例是一个副本"
msgstr "Instance name, each instance is a replica"

#: hetu/cli/start.py:95
msgid "监听的Websocket端口"
msgstr "Websocket port to listen on"

#: hetu/cli/start.py:100
msgid "后端数据库地址"
msgstr "Backend database address"

#: hetu/cli/start.py:104
msgid "工作进程数，可设为 CPU * 1.2"
msgstr "Number of worker processes, can be set to CPU * 1.2"

#: hetu/cli/start.py:112
msgid ""
"开启debug模式，这会启动代码热更新，并显示更多的log信息。如果设置为2，则对框架内核也启用debug模式，会开启Python协程的Debug模式，速度慢90％。"
msgstr ""
"Enable debug mode. This will start code hot reloading and show more log "
"information. If set to 2, debug mode is also enabled for the framework core,"
" which activates Python coroutine Debug mode, slowing down by 90%."

#: hetu/cli/start.py:122
msgid "证书目录，如果不设置则使用不安全的连接。不建议这里设置，请外加一层反向https代理。填入auto会生成自签https证书。"
msgstr ""
"Certificate directory. If not set, an insecure connection is used. It is not"
" recommended to set this here; please add an external reverse HTTPS proxy "
"layer. Enter 'auto' to generate a self-signed HTTPS certificate."

#: hetu/cli/start.py:130
msgid "默认crypto层的auth_key，用于握手签名校验。留空则不启用。"
msgstr ""
"Default auth_key for the crypto layer, used for handshake signature "
"verification. Leave empty to disable."

#: hetu/cli/start.py:137
msgid "配置文件模板见CONFIG_TEMPLATE.yml"
msgstr "Configuration file template: CONFIG_TEMPLATE.yml"

#: hetu/cli/start.py:155
msgid "--app_file是必须参数，或者用--config"
msgstr "--app_file is a required parameter, or use --config"

#: hetu/cli/start.py:158
msgid "--namespace是必须参数，或者用--config"
msgstr "--namespace is a required parameter, or use --config"

#: hetu/cli/start.py:161
msgid "--instance是必须参数，或者用--config"
msgstr "--instance is a required parameter, or use --config"

#: hetu/cli/start.py:218
#, python-brace-format
msgid "ℹ️ {name}, {mode}, {workers} 个工作进程, 管理进程 pid: {pid}"
msgstr ""
"ℹ️ {name}, {mode}, {workers} worker processes, manager process pid: {pid}"

#: hetu/cli/start.py:226
#, python-brace-format
msgid "ℹ️ Python {version} 平台 {platform}"
msgstr "ℹ️ Python {version} platform {platform}"

#: hetu/cli/start.py:231
#, python-brace-format
msgid "📡 监听地址： http{s}://{host}:{port}"
msgstr "📡 Listening address: http{s}://{host}:{port}"

#: hetu/cli/start.py:237
#, python-brace-format
msgid "ℹ️ 消息流协议：json -> {layers} -> Network"
msgstr "ℹ️ Message flow protocol: json -> {layers} -> Network"

#: hetu/cli/start.py:244
msgid "⚠️⚠️⚠️ 深度Debug模式开启  ⚠️⚠️⚠️   此模式下Python协程慢90%"
msgstr ""
"⚠️⚠️⚠️ Deep Debug Mode Enabled  ⚠️⚠️⚠️   Python coroutines are 90% slower in"
" this mode."
