#: hetu/data/component.py:253
msgid "Component重复定义"
msgstr "Component duplicate definition"

#: hetu/data/component.py:369
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是Python关键字。"
msgstr ""
"{cname}.{fname} property definition error: property name cannot be a "
"Python keyword."

#: hetu/data/component.py:375
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是C#关键字。"
msgstr ""
"{cname}.{fname} property definition error: property name cannot be a C# "
"keyword."

#: hetu/data/component.py:381
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不能为0长度。str类型请用'<U8'方式定义"
msgstr ""
"{cname}.{fname} property dtype cannot be zero length. For str type, "
"please define it using '<U8' format."

#: hetu/data/component.py:384
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不支持void类型"
msgstr "{cname}.{fname} property dtype does not support void type."

#: hetu/data/component.py:394
#, python-brace-format
msgid "⚠️ [🛠️Define] {cname}.{fname}属性设置为unique时，index不能设置为False。"
msgstr ""
"⚠️ [🛠️Define] When {cname}.{fname} property is set to unique, index "
"cannot be set to False."

#: hetu/data/component.py:401
#, python-brace-format
msgid ""
"{cname}.{fname}默认值不能为None。所有属性都要有默认值，因为数据接口统一用c like "
"struct实现，强类型struct不接受NULL/None值。"
msgstr ""
"{cname}.{fname} default value cannot be None. All properties must have "
"default values because the data interface is uniformly implemented using "
"C-like structs, and strongly-typed structs do not accept NULL/None "
"values."

#: hetu/data/component.py:412
#, python-brace-format
msgid "{cname}.{fname}的default值：{default_type}({default_value})和属性dtype({dtype})不匹配"
msgstr ""
"{cname}.{fname} default value: {default_type}({default_value}) does not "
"match property dtype ({dtype})."

#: hetu/data/component.py:426
#, python-brace-format
msgid "{cname}权限为OWNER时，不能设置rls_compare参数"
msgstr "When {cname} permission is OWNER, the rls_compare parameter cannot be set."

#: hetu/data/component.py:429
#, python-brace-format
msgid "{cname}权限为OWNER时，必须有owner属性"
msgstr "When {cname} permission is OWNER, it must have an owner property."

#: hetu/data/component.py:436
#, python-brace-format
msgid "{cname}的owner属性必需是numeric数字(int, np.int64, ...)类型"
msgstr "{cname}'s owner property must be a numeric type (int, np.int64, ...)."

#: hetu/data/component.py:442
#, python-brace-format
msgid "{cname}权限为RLS时，必须通过rls_compare参数定义行级权限逻辑"
msgstr ""
"When {cname} permission is RLS, the row-level permission logic must be "
"defined via the rls_compare parameter."

#: hetu/data/component.py:445
#, python-brace-format
msgid "{cname}.rls_compare参数必须全部是字符串类型"
msgstr "{cname}.rls_compare parameters must all be string types."

#: hetu/data/component.py:448
#, python-brace-format
msgid "{cname}.rls_compare参数必须只有3个元素)"
msgstr "{cname}.rls_compare parameter must have exactly 3 elements."

#: hetu/data/component.py:452
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但operator模块没有{method}方法"
msgstr ""
"{cname} permission is RLS: {rls_compare}, but the operator module does "
"not have the {method} method."

#: hetu/data/component.py:456
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但表没有定义{prop}属性"
msgstr ""
"{cname} permission is RLS: {rls_compare}, but the table does not define "
"the {prop} property."

#: hetu/data/component.py:463
#, python-brace-format
msgid "组件名({name})是C#关键字，请refactor。"
msgstr "Component name ({name}) is a C# keyword, please refactor."

#: hetu/data/component.py:476
#, python-brace-format
msgid "{cls_name}.{name}不是Property类型"
msgstr "{cls_name}.{name} is not of Property type."

#: hetu/data/component.py:486
#, python-brace-format
msgid "{cls_name}.{name}属性未定义type hint。请使用以下形式，{name}: type = property_field(...)"
msgstr ""
"{cls_name}.{name} property does not have a type hint defined. Please use "
"the following format: {name}: type = property_field(...)"

#: hetu/data/component.py:491
#, python-brace-format
msgid "{cls_name}至少要有1个Property成员"
msgstr "{cls_name} must have at least 1 Property member."

#: hetu/data/component.py:497
#, python-brace-format
msgid "{cls_name}.id是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}.id is a reserved built-in primary key and cannot be redefined "
"externally."

#: hetu/data/component.py:500
#, python-brace-format
msgid "{cls_name}._version是保留的内置主键，外部不能重定义"
msgstr ""
"{cls_name}._version is a reserved built-in primary key and cannot be "
"redefined externally."

#: hetu/data/component.py:509
#, python-brace-format
msgid "{cls_name}必须继承于BaseComponent"
msgstr "{cls_name} must inherit from BaseComponent."

