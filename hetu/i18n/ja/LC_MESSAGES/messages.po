#: hetu/data/component.py:253
msgid "Component重复定义"
msgstr "Componentの重複定義"

#: hetu/data/component.py:369
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是Python关键字。"
msgstr "{cname}.{fname}属性の定義エラー：属性名はPythonのキーワードにできません。"

#: hetu/data/component.py:375
#, python-brace-format
msgid "{cname}.{fname}属性定义出错，属性名不能是C#关键字。"
msgstr "{cname}.{fname}属性の定義エラー：属性名はC#のキーワードにできません。"

#: hetu/data/component.py:381
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不能为0长度。str类型请用'<U8'方式定义"
msgstr "{cname}.{fname}属性のdtypeは長さ0にできません。str型は'<U8'のような形式で定義してください。"

#: hetu/data/component.py:384
#, python-brace-format
msgid "{cname}.{fname}属性的dtype不支持void类型"
msgstr "{cname}.{fname}属性のdtypeはvoid型をサポートしていません。"

#: hetu/data/component.py:394
#, python-brace-format
msgid "⚠️ [🛠️Define] {cname}.{fname}属性设置为unique时，index不能设置为False。"
msgstr "⚠️ [🛠️Define] {cname}.{fname}属性をuniqueに設定する場合、indexをFalseに設定できません。"

#: hetu/data/component.py:401
#, python-brace-format
msgid ""
"{cname}.{fname}默认值不能为None。所有属性都要有默认值，因为数据接口统一用c like "
"struct实现，强类型struct不接受NULL/None值。"
msgstr "{cname}.{fname}のデフォルト値をNoneにできません。すべての属性にはデフォルト値が必要です。データインターフェースはC言語風のstructで統一実装されており、強力な型付けを持つstructはNULL/None値を受け付けません。"

#: hetu/data/component.py:412
#, python-brace-format
msgid "{cname}.{fname}的default值：{default_type}({default_value})和属性dtype({dtype})不匹配"
msgstr "{cname}.{fname}のdefault値：{default_type}({default_value})と属性のdtype({dtype})が一致しません。"

#: hetu/data/component.py:426
#, python-brace-format
msgid "{cname}权限为OWNER时，不能设置rls_compare参数"
msgstr "{cname}の権限がOWNERの場合、rls_compareパラメータを設定できません。"

#: hetu/data/component.py:429
#, python-brace-format
msgid "{cname}权限为OWNER时，必须有owner属性"
msgstr "{cname}の権限がOWNERの場合、owner属性が必要です。"

#: hetu/data/component.py:436
#, python-brace-format
msgid "{cname}的owner属性必需是numeric数字(int, np.int64, ...)类型"
msgstr "{cname}のowner属性は数値型（int, np.int64, ...）でなければなりません。"

#: hetu/data/component.py:442
#, python-brace-format
msgid "{cname}权限为RLS时，必须通过rls_compare参数定义行级权限逻辑"
msgstr "{cname}の権限がRLSの場合、rls_compareパラメータで行レベル権限ロジックを定義する必要があります。"

#: hetu/data/component.py:445
#, python-brace-format
msgid "{cname}.rls_compare参数必须全部是字符串类型"
msgstr "{cname}.rls_compareパラメータはすべて文字列型でなければなりません。"

#: hetu/data/component.py:448
#, python-brace-format
msgid "{cname}.rls_compare参数必须只有3个元素)"
msgstr "{cname}.rls_compareパラメータは3つの要素のみでなければなりません。"

#: hetu/data/component.py:452
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但operator模块没有{method}方法"
msgstr "{cname}の権限がRLS: {rls_compare}ですが、operatorモジュールに{method}メソッドがありません。"

#: hetu/data/component.py:456
#, python-brace-format
msgid "{cname}权限为RLS: {rls_compare}，但表没有定义{prop}属性"
msgstr "{cname}の権限がRLS: {rls_compare}ですが、テーブルに{prop}属性が定義されていません。"

#: hetu/data/component.py:463
#, python-brace-format
msgid "组件名({name})是C#关键字，请refactor。"
msgstr "コンポーネント名({name})はC#のキーワードです。リファクタリングしてください。"

#: hetu/data/component.py:476
#, python-brace-format
msgid "{cls_name}.{name}不是Property类型"
msgstr "{cls_name}.{name}はProperty型ではありません。"

#: hetu/data/component.py:486
#, python-brace-format
msgid "{cls_name}.{name}属性未定义type hint。请使用以下形式，{name}: type = property_field(...)"
msgstr ""
"{cls_name}.{name}属性に型ヒントが定義されていません。次の形式を使用してください：{name}: type = "
"property_field(...)"

#: hetu/data/component.py:491
#, python-brace-format
msgid "{cls_name}至少要有1个Property成员"
msgstr "{cls_name}には少なくとも1つのPropertyメンバーが必要です。"

#: hetu/data/component.py:497
#, python-brace-format
msgid "{cls_name}.id是保留的内置主键，外部不能重定义"
msgstr "{cls_name}.idは組み込みの主キーとして予約されており、外部から再定義できません。"

#: hetu/data/component.py:500
#, python-brace-format
msgid "{cls_name}._version是保留的内置主键，外部不能重定义"
msgstr "{cls_name}._versionは組み込みの主キーとして予約されており、外部から再定義できません。"

#: hetu/data/component.py:509
#, python-brace-format
msgid "{cls_name}必须继承于BaseComponent"
msgstr "{cls_name}はBaseComponentを継承しなければなりません。"

#: hetu/data/migration.py:39
#, python-brace-format
msgid "  ➖ [💾Redis][{comp_name}组件] 发现自定义迁移脚本 {file}，将调用脚本进行迁移..."
msgstr ""
"  ➖ [💾Redis][{comp_name}コンポーネント] カスタムマイグレーションスクリプト {file} "
"を検出しました。スクリプトを呼び出してマイグレーションを実行します..."

#: hetu/data/migration.py:88
#, python-brace-format
msgid ""
"  ➖ [💾Redis][{comp_name}组件] 缺少迁移脚本，生成默认迁移脚本 "
"{script_path}，请根据需要修改脚本内容后再执行迁移操作..."
msgstr ""
"  ➖ [💾Redis][{comp_name}コンポーネント] "
"マイグレーションスクリプトが不足しています。デフォルトのマイグレーションスクリプト {script_path} "
"を生成しました。必要に応じてスクリプトの内容を変更してからマイグレーション操作を実行してください..."

#: hetu/data/migration.py:200
#, python-brace-format
msgid "  ➖ [💾Redis][{comp_name}组件] 执行upgrade迁移：{module}"
msgstr "  ➖ [💾Redis][{comp_name}コンポーネント] upgradeマイグレーションを実行中：{module}"

#: hetu/data/migration.py:207
#, python-brace-format
msgid "  ✔️ [💾Redis][{comp_name}组件] Schema升级迁移完成，共处理{count}行"
msgstr ""
"  ✔️ [💾Redis][{comp_name}コンポーネント] "
"Schemaアップグレードマイグレーションが完了しました。合計{count}行を処理しました"

#: hetu/data/migration.py:212
#, python-brace-format
msgid "  ✔️ [💾Redis][{comp_name}组件] 已重建Index"
msgstr "  ✔️ [💾Redis][{comp_name}コンポーネント] Indexを再構築しました"

#: hetu/data/sub.py:179
#, python-brace-format
