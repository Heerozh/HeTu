#: hetu/cli/start.py:52
#, python-brace-format
msgid ""
"不支持的数据库URL scheme: '{scheme}'。目前支持 "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb"
msgstr ""
"サポートされていないデータベースURLスキーム: '{scheme}'。現在サポートされているのは "
"redis/rediss/valkey/valkeys/postgres/postgresql/sqlite/mysql/mariadb です"

#: hetu/cli/start.py:77
msgid "启动河图服务"
msgstr "河図サービスを起動"

#: hetu/cli/start.py:79
msgid "通过命令行启动参数"
msgstr "コマンドライン起動引数による"

#: hetu/cli/start.py:82
msgid "河图app的py文件"
msgstr "河図アプリのpyファイル"

#: hetu/cli/start.py:89
msgid "启动app.py中哪个namespace下的System"
msgstr "app.py内のどのnamespaceのSystemを起動するか"

#: hetu/cli/start.py:92
msgid "实例名称，每个实例是一个副本"
msgstr "インスタンス名。各インスタンスは1つのレプリカです"

#: hetu/cli/start.py:95
msgid "监听的Websocket端口"
msgstr "Websocketの待ち受けポート"

#: hetu/cli/start.py:100
msgid "后端数据库地址"
msgstr "バックエンドデータベースアドレス"

#: hetu/cli/start.py:104
msgid "工作进程数，可设为 CPU * 1.2"
msgstr "ワーカープロセス数。CPU * 1.2 に設定可能"

#: hetu/cli/start.py:112
msgid ""
"开启debug模式，这会启动代码热更新，并显示更多的log信息。如果设置为2，则对框架内核也启用debug模式，会开启Python协程的Debug模式，速度慢90％。"
msgstr ""
"デバッグモードを有効化。これによりコードのホットリロードが開始され、より多くのログ情報が表示されます。2に設定すると、フレームワークカーネルにもデバッグモードが有効化され、Pythonコルーチンのデバッグモードがオンになり、速度が90％低下します。"

#: hetu/cli/start.py:122
msgid "证书目录，如果不设置则使用不安全的连接。不建议这里设置，请外加一层反向https代理。填入auto会生成自签https证书。"
msgstr ""
"証明書ディレクトリ。設定しない場合は安全でない接続を使用します。ここでの設定は推奨されません。外部にリバースHTTPSプロキシを追加してください。autoを入力すると自己署名HTTPS証明書が生成されます。"

#: hetu/cli/start.py:130
msgid "默认crypto层的auth_key，用于握手签名校验。留空则不启用。"
msgstr "デフォルトのcrypto層のauth_key。ハンドシェイク署名検証に使用されます。空欄の場合は有効になりません。"

#: hetu/cli/start.py:137
msgid "配置文件模板见CONFIG_TEMPLATE.yml"
msgstr "設定ファイルテンプレートはCONFIG_TEMPLATE.ymlを参照"

#: hetu/cli/start.py:155
msgid "--app_file是必须参数，或者用--config"
msgstr "--app_fileは必須パラメータです。または--configを使用してください"

#: hetu/cli/start.py:158
msgid "--namespace是必须参数，或者用--config"
msgstr "--namespaceは必須パラメータです。または--configを使用してください"

#: hetu/cli/start.py:161
msgid "--instance是必须参数，或者用--config"
msgstr "--instanceは必須パラメータです。または--configを使用してください"

#: hetu/cli/start.py:218
#, python-brace-format
msgid "ℹ️ {name}, {mode}, {workers} 个工作进程, 管理进程 pid: {pid}"
msgstr "ℹ️ {name}, {mode}, {workers} ワーカープロセス, 管理プロセス pid: {pid}"

#: hetu/cli/start.py:226
#, python-brace-format
msgid "ℹ️ Python {version} 平台 {platform}"
msgstr "ℹ️ Python {version} プラットフォーム {platform}"

#: hetu/cli/start.py:231
#, python-brace-format
msgid "📡 监听地址： http{s}://{host}:{port}"
msgstr "📡 待ち受けアドレス： http{s}://{host}:{port}"

#: hetu/cli/start.py:237
#, python-brace-format
msgid "ℹ️ 消息流协议：json -> {layers} -> Network"
msgstr "ℹ️ メッセージストリームプロトコル：json -> {layers} -> Network"

#: hetu/cli/start.py:244
msgid "⚠️⚠️⚠️ 深度Debug模式开启  ⚠️⚠️⚠️   此模式下Python协程慢90%"
msgstr "⚠️⚠️⚠️ 深度デバッグモード有効化  ⚠️⚠️⚠️   このモードではPythonコルーチンが90%遅くなります"
